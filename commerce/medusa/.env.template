# ============================================================
# Piece of Stass — Medusa.js v2 Backend Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ============================================================

# ─── Node ────────────────────────────────────────────────────
NODE_ENV=development

# ─── Medusa Core ─────────────────────────────────────────────
MEDUSA_BACKEND_URL=https://api.pieceofstass.com
JWT_SECRET=change_me_at_least_32_chars_random
COOKIE_SECRET=change_me_at_least_32_chars_random

# ─── Database (Neon Postgres) ─────────────────────────────────
# Format: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Redis (Upstash) ─────────────────────────────────────────
# Format: rediss://default:token@endpoint:6380
REDIS_URL=rediss://default:token@your-endpoint.upstash.io:6380

# ─── CORS ────────────────────────────────────────────────────
STORE_CORS=https://pieceofstass.com,https://www.pieceofstass.com
ADMIN_CORS=https://admin.pieceofstass.com
AUTH_CORS=https://pieceofstass.com,https://www.pieceofstass.com,https://admin.pieceofstass.com

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Tax: enabled automatically via medusa-payment-stripe when Stripe Tax is
# activated on the Stripe dashboard for the account. No additional env var needed.

# ─── SendGrid (transactional email) ──────────────────────────
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=orders@pieceofstass.com

# ─── SMTP (supplier notification emails) ─────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxx
SUPPLIER_NOTIFY_FROM=ops@pieceofstass.com

# ─── Supplier Contact Emails ─────────────────────────────────
