# ─── Klaviyo ─────────────────────────────────────────────────
KLAVIYO_API_KEY=pk_xxx
KLAVIYO_ORDER_PLACED_METRIC_ID=xxxxx
KLAVIYO_ORDER_SHIPPED_METRIC_ID=xxxxx

# ─── Meta CAPI ───────────────────────────────────────────────
