# Cloudflare Workers local development variables
# This file is automatically loaded by `wrangler dev` / `astro dev` with platformProxy.
# DO NOT commit secrets to version control — add .dev.vars to .gitignore.
#
# Generate ADMIN_PASSWORD_HASH:
#   echo "yourpassword" | node scripts/seed-admin-password.mjs
