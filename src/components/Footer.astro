---
import EmailSignup from './islands/EmailSignup';
import { SOCIAL_LINKS } from '../lib/social-links';
---

<footer style="background-color: var(--color-espresso); border-top: 1px solid rgba(246,240,232,0.10); padding: 64px 16px 32px;">
  <div style="max-width: 1280px; margin: 0 auto;">
    <!-- Newsletter -->
    <div style="background: linear-gradient(135deg, rgba(178,94,107,0.16) 0%, rgba(196,103,61,0.14) 100%); border: 1px solid rgba(246,240,232,0.10); border-radius: var(--radius-xl); padding: 40px 32px; margin-bottom: 64px; text-align: center;">
      <p style="font-family: var(--font-family-mono); font-size: 11px; letter-spacing: 0.08em; color: var(--color-rose-bright); text-transform: uppercase; margin: 0 0 8px;">Join the stash</p>
      <h2 style="font-family: var(--font-family-display); font-weight: 700; font-size: 30px; letter-spacing: -0.02em; margin: 0 0 8px; color: var(--color-cream);">Get 10% off your first order</h2>
      <p style="color: #B8A795; font-size: 14px; margin: 0 0 24px;">New drops, early access, and the occasional cheeky email. Unsubscribe any time.</p>
      <EmailSignup client:visible />
    </div>

    <!-- Links grid -->
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px; margin-bottom: 48px;">
      <!-- Brand col -->
      <div>
        <a href="/" style="display: flex; align-items: center; gap: 8px; text-decoration: none; margin-bottom: 16px;">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <rect width="32" height="32" rx="6" fill="var(--color-rose)" />
            <path d="M9 7h8c2.761 0 5 2.239 5 5s-2.239 5-5 5H9V7z" fill="var(--color-cream)" />
            <path d="M9 17v8" stroke="var(--color-cream)" stroke-width="3" stroke-linecap="round" />
          </svg>
          <span style="font-family: var(--font-family-display); font-weight: 700; font-size: 16px; color: var(--color-cream);">STASS</span>
        </a>
        <p style="color: #B8A795; font-size: 13px; line-height: 1.6; max-width: 260px;">We don't sell everything. We sell the edit. Trend-driven finds across 8 categories, dropped daily.</p>
        <!-- Social links — sourced from social-links.ts -->
        <div style="display: flex; gap: 12px; margin-top: 16px; flex-wrap: wrap;">
          <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" style="color: #B8A795; transition: color 150ms;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href={SOCIAL_LINKS.tiktok} target="_blank" rel="noopener noreferrer" aria-label="TikTok" style="color: #B8A795; transition: color 150ms;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.16 8.16 0 004.77 1.52V6.76a4.85 4.85 0 01-1-.07z"/></svg>
          </a>
          <a href={SOCIAL_LINKS.pinterest} target="_blank" rel="noopener noreferrer" aria-label="Pinterest" style="color: #B8A795; transition: color 150ms;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
          </a>
          <a href={SOCIAL_LINKS.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" style="color: #B8A795; transition: color 150ms;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={SOCIAL_LINKS.snap} target="_blank" rel="noopener noreferrer" aria-label="Snapchat" style="color: #B8A795; transition: color 150ms;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.206.793c.99 0 4.347.276 5.93 3.821.529 1.193.403 3.219.333 4.21-.005.082.022.107.07.124.217.078 1.047.252 1.047 1.241 0 .655-.36 1.051-.72 1.154-.077.021-.156.043-.235.065.171.426.565.93 1.128 1.421.56.487 1.14.8 1.578.893.43.09.754.42.754.78 0 .37-.258.67-.626.757-.354.083-1.002.224-1.546.415a.97.97 0 0 0-.462.27c-.219.245-.206.527-.203.542.031.397.23 1.297 1.135 1.297.1 0 .206-.016.321-.047.117-.032.22-.047.317-.047.315 0 .68.113.68.59 0 .7-.685 1.118-1.462 1.118-.33 0-.618-.095-.834-.141-.47-.098-.805-.158-1.2-.158-.23 0-.484.012-.756.054.035.217.044.448.044.653 0 2.286-1.724 4.046-4.044 4.046-.047 0-.097-.004-.147-.006-.195.01-.392.022-.605.022-2.322 0-4.044-1.76-4.044-4.046 0-.207.009-.436.044-.653-.272-.042-.528-.054-.756-.054-.394 0-.73.06-1.2.158-.216.046-.504.141-.834.141-.777 0-1.462-.418-1.462-1.118 0-.477.365-.59.68-.59.097 0 .2.015.317.047.115.031.221.047.321.047.905 0 1.104-.9 1.135-1.297.003-.015.016-.297-.203-.542a.97.97 0 0 0-.462-.27c-.544-.191-1.192-.332-1.546-.415-.368-.087-.626-.387-.626-.757 0-.36.324-.69.754-.78.438-.093 1.018-.406 1.578-.893.563-.491.957-.995 1.128-1.421-.079-.022-.158-.044-.235-.065-.36-.103-.72-.499-.72-1.154 0-.989.83-1.163 1.047-1.241.048-.017.075-.042.07-.124-.07-.991-.196-3.017.333-4.21C7.853 1.07 11.218.793 12.206.793z"/></svg>
          </a>
        </div>
      </div>

      <!-- Shop col -->
      <div>
        <h3 style="font-size: 11px; font-family: var(--font-family-mono); letter-spacing: 0.08em; color: #B8A795; text-transform: uppercase; margin: 0 0 16px;">Shop</h3>
        <nav aria-label="Shop categories">
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
            <li><a href="/shop" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85; hover:opacity: 1;">New arrivals</a></li>
            <li><a href="/shop/footwear" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Footwear</a></li>
            <li><a href="/shop/bags" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Bags</a></li>
            <li><a href="/shop/watches" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Watches</a></li>
            <li><a href="/shop/women" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Women</a></li>
            <li><a href="/shop/men" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Men</a></li>
            <li><a href="/shop/fragrance" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Fragrance</a></li>
            <li><a href="/shop/tech" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Tech</a></li>
          </ul>
        </nav>
      </div>

      <!-- Help col -->
      <div>
        <h3 style="font-size: 11px; font-family: var(--font-family-mono); letter-spacing: 0.08em; color: #B8A795; text-transform: uppercase; margin: 0 0 16px;">Help</h3>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
          <li><a href="/track-order" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Track order</a></li>
          <li><a href="/returns" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Returns & refunds</a></li>
          <li><a href="/shipping" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Shipping info</a></li>
          <li><a href="/about-anna" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">About Anna</a></li>
          <li><a href="/blog" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">The edit (blog)</a></li>
        </ul>
      </div>

      <!-- Legal col -->
      <div>
        <h3 style="font-size: 11px; font-family: var(--font-family-mono); letter-spacing: 0.08em; color: #B8A795; text-transform: uppercase; margin: 0 0 16px;">Legal</h3>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
          <li><a href="/terms" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Terms of service</a></li>
          <li><a href="/privacy" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Privacy policy</a></li>
          <li><a href="/cookies" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Cookie policy</a></li>
          <li><a href="/acceptable-use" style="color: var(--color-cream); font-size: 14px; text-decoration: none; opacity: 0.85;">Acceptable use</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="border-top: 1px solid rgba(246,240,232,0.10); padding-top: 24px; display: flex; flex-wrap: wrap; gap: 12px; justify-content: space-between; align-items: center;">
      <p style="color: #B8A795; font-size: 12px; margin: 0;">&copy; 2025 Piece of Stass. All rights reserved.</p>
      <p style="color: #B8A795; font-size: 12px; margin: 0; font-family: var(--font-family-mono);">#RaidTheStash</p>
    </div>
  </div>
</footer>

<style>
  footer a:hover {
    color: var(--color-cream) !important;
    opacity: 1 !important;
    text-decoration: underline !important;
    text-decoration-color: var(--color-rose-bright) !important;
    text-underline-offset: 4px !important;
  }
  @media (min-width: 768px) {
    footer > div > div:nth-child(2) {
      grid-template-columns: repeat(4, 1fr) !important;
    }
  }
</style>
