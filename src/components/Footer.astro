---
import EmailSignup from './islands/EmailSignup';
---

<footer style="background-color: var(--color-charcoal); border-top: 1px solid var(--color-slate); padding: 64px 16px 32px;">
  <div style="max-width: 1280px; margin: 0 auto;">
    <!-- Newsletter -->
    <div style="background: linear-gradient(135deg, rgba(198,255,58,0.08) 0%, rgba(123,92,255,0.08) 100%); border: 1px solid var(--color-slate); border-radius: var(--radius-xl); padding: 40px 32px; margin-bottom: 64px; text-align: center;">
      <p style="font-family: var(--font-family-mono); font-size: 11px; letter-spacing: 0.08em; color: var(--color-lime); text-transform: uppercase; margin: 0 0 8px;">Join the stash</p>
      <h2 style="font-family: var(--font-family-display); font-weight: 700; font-size: 30px; letter-spacing: -0.02em; margin: 0 0 8px; color: var(--color-paper);">Get 10% off your first order</h2>
      <p style="color: var(--color-muted); font-size: 14px; margin: 0 0 24px;">New drops, early access, and the occasional cheeky email. Unsubscribe any time.</p>
      <EmailSignup client:visible />
    </div>

    <!-- Links grid -->
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px; margin-bottom: 48px;">
      <!-- Brand col -->
      <div>
        <a href="/" style="display: flex; align-items: center; gap: 8px; text-decoration: none; margin-bottom: 16px;">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <rect width="32" height="32" rx="6" fill="var(--color-lime)" />
            <path d="M9 7h8c2.761 0 5 2.239 5 5s-2.239 5-5 5H9V7z" fill="var(--color-ink)" />
            <path d="M9 17v8" stroke="var(--color-ink)" stroke-width="3" stroke-linecap="round" />
          </svg>
          <span style="font-family: var(--font-family-display); font-weight: 700; font-size: 16px; color: var(--color-paper);">STASS</span>
        </a>
        <p style="color: var(--color-muted); font-size: 13px; line-height: 1.6; max-width: 260px;">We don't sell everything. We sell the edit. Trend-driven finds across 8 categories, dropped daily.</p>
        <div style="display: flex; gap: 12px; margin-top: 16px;">
          <a href="https://instagram.com/pieceofstass" target="_blank" rel="noopener noreferrer" aria-label="Instagram" style="color: var(--color-muted); transition: color 150ms;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="https://tiktok.com/@pieceofstass" target="_blank" rel="noopener noreferrer" aria-label="TikTok" style="color: var(--color-muted); transition: color 150ms;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.16 8.16 0 004.77 1.52V6.76a4.85 4.85 0 01-1-.07z"/></svg>
          </a>
        </div>
      </div>

      <!-- Shop col -->
      <div>
        <h3 style="font-size: 11px; font-family: var(--font-family-mono); letter-spacing: 0.08em; color: var(--color-muted); text-transform: uppercase; margin: 0 0 16px;">Shop</h3>
        <nav aria-label="Shop categories">
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
            <li><a href="/shop" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85; hover:opacity: 1;">New arrivals</a></li>
            <li><a href="/shop/footwear" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Footwear</a></li>
            <li><a href="/shop/bags" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Bags</a></li>
            <li><a href="/shop/watches" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Watches</a></li>
            <li><a href="/shop/women" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Women</a></li>
            <li><a href="/shop/men" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Men</a></li>
            <li><a href="/shop/fragrance" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Fragrance</a></li>
            <li><a href="/shop/tech" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Tech</a></li>
          </ul>
        </nav>
      </div>

      <!-- Help col -->
      <div>
        <h3 style="font-size: 11px; font-family: var(--font-family-mono); letter-spacing: 0.08em; color: var(--color-muted); text-transform: uppercase; margin: 0 0 16px;">Help</h3>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
          <li><a href="/track-order" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Track order</a></li>
          <li><a href="/returns" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Returns & refunds</a></li>
          <li><a href="/shipping" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Shipping info</a></li>
          <li><a href="/about-anna" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">About Anna</a></li>
          <li><a href="/blog" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">The edit (blog)</a></li>
        </ul>
      </div>

      <!-- Legal col -->
      <div>
        <h3 style="font-size: 11px; font-family: var(--font-family-mono); letter-spacing: 0.08em; color: var(--color-muted); text-transform: uppercase; margin: 0 0 16px;">Legal</h3>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
          <li><a href="/terms" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Terms of service</a></li>
          <li><a href="/privacy" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Privacy policy</a></li>
          <li><a href="/cookies" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Cookie policy</a></li>
          <li><a href="/acceptable-use" style="color: var(--color-paper); font-size: 14px; text-decoration: none; opacity: 0.85;">Acceptable use</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="border-top: 1px solid var(--color-slate); padding-top: 24px; display: flex; flex-wrap: wrap; gap: 12px; justify-content: space-between; align-items: center;">
      <p style="color: var(--color-muted); font-size: 12px; margin: 0;">&copy; 2025 Piece of Stass. All rights reserved.</p>
      <p style="color: var(--color-muted); font-size: 12px; margin: 0; font-family: var(--font-family-mono);">#RaidTheStash</p>
    </div>
  </div>
</footer>

<style>
  footer a:hover {
    color: var(--color-lime) !important;
    opacity: 1 !important;
  }
  @media (min-width: 768px) {
    footer > div > div:nth-child(2) {
      grid-template-columns: repeat(4, 1fr) !important;
    }
  }
</style>
