---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogSquareImage?: string; // 600x600 for iMessage/WhatsApp square crop
  ogType?: 'website' | 'product' | 'article' | 'profile';
  ogImageAlt?: string;
  jsonLd?: object | object[];
  noindex?: boolean;
  // Product-specific (PDPs — Facebook Shop, Pinterest Rich Pins)
  productPrice?: number;
  productCurrency?: string;
  productAvailability?: 'in stock' | 'out of stock' | 'preorder';
  productCondition?: string;
  productBrand?: string;
  productSku?: string;
  // og:see_also (array of related URLs — used on home for social profiles)
  seeAlso?: string[];
  // Article-specific
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-default.png',
  ogSquareImage,
  ogType = 'website',
  ogImageAlt,
  jsonLd,
  noindex = false,
  productPrice,
  productCurrency = 'USD',
  productAvailability = 'in stock',
  productCondition = 'new',
  productBrand = 'Piece of Stass',
  productSku,
  seeAlso,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://pieceofstass.com';
const canonicalUrl = canonical ? canonical : `${siteUrl}${Astro.url.pathname}`;

// Ensure absolute URLs
const ogImageFull = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const ogSquareImageFull = ogSquareImage
  ? (ogSquareImage.startsWith('http') ? ogSquareImage : `${siteUrl}${ogSquareImage}`)
  : null;

// Enforce LinkedIn limits: title ≤ 70 chars, description ≤ 200 chars
const safeTitle = title.length > 70 ? title.slice(0, 67) + '…' : title;
const safeDesc = description.length > 200 ? description.slice(0, 197) + '…' : description;

const resolvedAlt = ogImageAlt || safeTitle;
const robotsValue = noindex ? 'noindex,nofollow' : 'index,follow';
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="robots" content={robotsValue} />

<!-- Language / Hreflang -->
<link rel="alternate" hreflang="x-default" href={canonicalUrl} />
<link rel="alternate" hreflang="en-us" href={canonicalUrl} />

<!-- Open Graph — primary 1200x630 image -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={safeTitle} />
<meta property="og:description" content={safeDesc} />
<meta property="og:image" content={ogImageFull} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:alt" content={resolvedAlt} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content="Piece of Stass" />
<meta property="og:locale" content="en_US" />

<!-- Open Graph — secondary 600x600 square crop (iMessage / WhatsApp fallback) -->
{ogSquareImageFull && (
  <>
    <meta property="og:image" content={ogSquareImageFull} />
    <meta property="og:image:width" content="600" />
    <meta property="og:image:height" content="600" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={resolvedAlt} />
  </>
)}

<!-- og:see_also — social profile links (home page) -->
{seeAlso?.map((url) => (
  <meta property="og:see_also" content={url} />
))}

<!-- Article meta -->
{ogType === 'article' && articlePublishedTime && (
  <meta property="article:published_time" content={articlePublishedTime} />
)}
{ogType === 'article' && articleModifiedTime && (
  <meta property="article:modified_time" content={articleModifiedTime} />
)}
{ogType === 'article' && articleAuthor && (
  <meta property="article:author" content={articleAuthor} />
)}
{ogType === 'article' && articleSection && (
  <meta property="article:section" content={articleSection} />
)}

<!-- Product meta — Facebook Shop, Pinterest Rich Pins -->
{ogType === 'product' && productPrice !== undefined && (
  <>
    <meta property="product:price:amount" content={productPrice.toFixed(2)} />
    <meta property="product:price:currency" content={productCurrency} />
    <meta property="product:availability" content={productAvailability} />
    <meta property="product:condition" content={productCondition} />
    <meta property="product:brand" content={productBrand} />
    {productSku && <meta property="product:retailer_item_id" content={productSku} />}
  </>
)}

<!-- Pinterest Rich Pins opt-in -->
<meta name="pinterest-rich-pin" content="true" />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@pieceofstass" />
<meta name="twitter:creator" content="@pieceofstass" />
<meta name="twitter:title" content={safeTitle} />
<meta name="twitter:description" content={safeDesc} />
<meta name="twitter:image" content={ogImageFull} />
<meta name="twitter:image:alt" content={resolvedAlt} />

<!-- Favicon & PWA (Piece of Stass laurel mark) -->
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
<link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="msapplication-config" content="/browserconfig.xml" />
<meta name="msapplication-TileColor" content="#2A211C" />
<meta name="theme-color" content="#F6F0E8" />

<!-- Preconnects & Resource Hints -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="dns-prefetch" href="https://fonts.googleapis.com" />

<!-- JSON-LD -->
{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])} />
)}
