---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchResultsIsland from '../components/islands/SearchResults';

const query = Astro.url.searchParams.get('q') || '';
---

<BaseLayout
  title={query ? `"${query}" — Search — Piece of Stass` : 'Search — Piece of Stass'}
  description="Search the stash. Find trend-driven footwear, bags, watches, fragrance, tech, and fits."
  noindex={true}
>
  <div style="max-width: 1280px; margin: 0 auto; padding: 40px 16px;">
    <h1 style="font-family: var(--font-family-display); font-weight: 700; font-size: clamp(24px, 4vw, 38px); letter-spacing: -0.02em; margin: 0 0 32px; color: var(--color-paper);">
      {query ? `Results for "${query}"` : 'Search the stash'}
    </h1>
    <SearchResultsIsland initialQuery={query} client:load />
  </div>
</BaseLayout>
