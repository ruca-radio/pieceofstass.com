---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import { listOrdersByUserId } from '../../../lib/users-server';

if (!Astro.locals.user) {
  return Astro.redirect('/account/sign-in');
}

const user = Astro.locals.user;
const env = (Astro.locals as Record<string, unknown>).runtime?.env as
  | Record<string, unknown>
  | undefined;

const orders = await listOrdersByUserId(user.id, env);

function formatCurrency(amount: number, currency = 'USD'): string {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency }).format(amount / 100);
}
function formatDate(iso: string): string {
  return new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(new Date(iso));
}

const statusColors: Record<string, string> = {
  pending:    '#9C6A22',
  processing: '#6F7B5F',
  shipped:    '#A14C58',
  delivered:  '#3F6A44',
  cancelled:  '#B23A33',
  refunded:   '#726558',
};
---

<BaseLayout
  title="Order History — Piece of Stass"
  description="View all your past orders."
  noindex
>
  <div style="max-width: 960px; margin: 0 auto; padding: 48px 16px 96px;">
    <!-- Breadcrumb -->
    <div style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--color-muted); margin-bottom: 32px;">
      <a href="/account" style="color: var(--color-muted); text-decoration: none; hover:color: var(--color-espresso);">Account</a>
      <span>›</span>
      <span style="color: var(--color-espresso);">Orders</span>
    </div>

    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; gap: 16px; flex-wrap: wrap;">
      <h1 style="font-family: var(--font-family-display); font-size: 28px; font-weight: 700; color: var(--color-espresso); letter-spacing: -0.03em;">
        Order history
      </h1>
      <span style="font-size: 14px; color: var(--color-muted);">{orders.length} order{orders.length !== 1 ? 's' : ''}</span>
    </div>

    {orders.length === 0 ? (
      <div style="text-align: center; padding: 80px 20px; background: var(--color-charcoal); border-radius: var(--radius-xl); border: 1px solid var(--color-slate);">
        <div style="font-size: 48px; margin-bottom: 16px; opacity: 0.4;">📦</div>
        <h2 style="font-size: 20px; font-weight: 700; color: var(--color-espresso); margin-bottom: 8px;">No orders yet</h2>
        <p style="font-size: 15px; color: var(--color-muted); margin-bottom: 24px;">When you place an order, it'll show up here.</p>
        <a href="/shop" style="display: inline-block; background: var(--color-lime); color: var(--color-cream); font-size: 15px; font-weight: 700; text-decoration: none; padding: 12px 28px; border-radius: var(--radius-pill);">
          Shop now
        </a>
      </div>
    ) : (
      <div style="display: flex; flex-direction: column; gap: 12px;">
        {orders.map((order) => (
          <a
            href={`/account/orders/${order.id}`}
            style="display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 16px; background: var(--color-charcoal); border: 1px solid var(--color-slate); border-radius: var(--radius-lg); padding: 20px 24px; text-decoration: none; transition: border-color 150ms;"
            class="order-card"
          >
            <div>
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 6px; flex-wrap: wrap;">
                <span style="font-family: var(--font-family-mono); font-size: 14px; color: var(--color-lime);">
                  #{order.id.slice(0, 8).toUpperCase()}
                </span>
                <span style={`font-size: 11px; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: ${statusColors[order.status] ?? '#726558'};`}>
                  {order.status}
                </span>
              </div>
              <div style="font-size: 13px; color: var(--color-muted);">
                {formatDate(order.created_at)} · {order.items.length} item{order.items.length !== 1 ? 's' : ''}
                {order.items.length > 0 && ` — ${order.items[0].title}${order.items.length > 1 ? ` + ${order.items.length - 1} more` : ''}`}
              </div>
            </div>
            <div style="text-align: right; flex-shrink: 0;">
              <div style="font-size: 16px; font-weight: 700; color: var(--color-espresso);">
                {formatCurrency(order.total, order.currency)}
              </div>
              <div style="font-size: 12px; color: var(--color-muted); margin-top: 2px;">View →</div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .order-card:hover {
    border-color: var(--color-muted) !important;
  }
</style>
