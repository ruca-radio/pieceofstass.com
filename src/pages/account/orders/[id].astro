---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getOrdersKVFromEnv, getOrder } from '../../../lib/orders-server';
import { resolveCarrier } from '../../../lib/tracking';
import { signJWT } from '../../../lib/auth';

if (!Astro.locals.user) {
  return Astro.redirect('/account/sign-in');
}

const user = Astro.locals.user;
const runtimeEnv = (Astro.locals as Record<string, unknown>).runtime?.env as
  | Record<string, unknown>
  | undefined;
const envVars = (runtimeEnv ?? {}) as Record<string, string | undefined>;
const authSecret = envVars.AUTH_SECRET ?? import.meta.env.AUTH_SECRET;

const { id } = Astro.params;
if (!id) return Astro.redirect('/account/orders');

const kv = getOrdersKVFromEnv(runtimeEnv);
const order = await getOrder(kv, id);

if (!order || order.customer_email !== user.email) {
  return Astro.redirect('/account/orders');
}

// Generate a 30-day signed token for the PDF receipt link
let receiptToken = '';
try {
  receiptToken = await signJWT(
    { order_id: order.id, type: 'receipt' },
    30 * 24 * 60 * 60,
    authSecret
  );
} catch {
  // Non-fatal
}

const carrierInfo = order.tracking_number ? resolveCarrier(order.tracking_number) : null;

function formatCurrency(amount: number): string {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(amount);
}
function formatDate(iso: string): string {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit'
  }).format(new Date(iso));
}
function addBizDays(d: Date, n: number): Date {
  const r = new Date(d);
  let added = 0;
  while (added < n) { r.setDate(r.getDate() + 1); if (r.getDay() !== 0 && r.getDay() !== 6) added++; }
  return r;
}

type StepInfo = { key: string; label: string; done: boolean; active: boolean };
const STEP_KEYS = ['payment_captured', 'sent_to_supplier', 'shipped', 'out_for_delivery', 'delivered'];
const STEP_LABELS: Record<string, string> = {
  payment_captured: 'Paid',
  sent_to_supplier: 'Processing',
  shipped: 'Shipped',
  out_for_delivery: 'Out for Delivery',
  delivered: 'Delivered',
};
const STEP_INDEX: Record<string, number> = {
  pending: -1, payment_captured: 0, sent_to_supplier: 1,
  shipped: 2, out_for_delivery: 3, delivered: 4, completed: 4,
};
const currentStepIdx = STEP_INDEX[order.status] ?? -1;

const steps: StepInfo[] = STEP_KEYS.map((key, i) => ({
  key,
  label: STEP_LABELS[key],
  done: i <= currentStepIdx,
  active: i === currentStepIdx,
}));

const isCancelled = order.status === 'cancelled';
const isRefunded = order.status === 'refunded';

const statusColors: Record<string, string> = {
  pending: '#9C6A22',
  payment_captured: '#6F7B5F',
  sent_to_supplier: '#6F7B5F',
  shipped: '#A14C58',
  out_for_delivery: '#A14C58',
  delivered: '#3F6A44',
  completed: '#3F6A44',
  cancelled: '#B23A33',
  refunded: '#726558',
};
const statusLabels: Record<string, string> = {
  pending: 'Pending', payment_captured: 'Paid', sent_to_supplier: 'Processing',
  shipped: 'Shipped', out_for_delivery: 'Out for Delivery', delivered: 'Delivered',
  completed: 'Complete', cancelled: 'Cancelled', refunded: 'Refunded',
};

const etaMin = addBizDays(new Date(order.created_at), 15);
const etaMax = addBizDays(new Date(order.created_at), 20);
const etaStr = `${etaMin.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })} – ${etaMax.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}`;

const orderNum = order.id.slice(-8).toUpperCase();
const receiptUrl = `/api/orders/${order.id}/invoice.pdf?token=${encodeURIComponent(receiptToken)}`;
const helpEmail = `mailto:help@pieceofstass.com?subject=Order%20${orderNum}`;
const statusColor = statusColors[order.status] ?? '#726558';
const statusLabel = statusLabels[order.status] ?? order.status;
---

<BaseLayout
  title={`Order #${orderNum} — Piece of Stass`}
  description="View your order details and tracking."
  noindex
>
  <div style="max-width: 880px; margin: 0 auto; padding: 48px 16px 96px;">

    <!-- Breadcrumb -->
    <div style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--color-muted); margin-bottom: 32px;">
      <a href="/account" style="color: var(--color-muted); text-decoration: none;">Account</a>
      <span>›</span>
      <a href="/account/orders" style="color: var(--color-muted); text-decoration: none;">Orders</a>
      <span>›</span>
      <span style="color: var(--color-espresso); font-family: var(--font-family-mono);">#{orderNum}</span>
    </div>

    <!-- Header -->
    <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 32px; flex-wrap: wrap;">
      <div>
        <h1 style="font-family: var(--font-family-display); font-size: 28px; font-weight: 700; color: var(--color-espresso); letter-spacing: -0.03em; margin: 0 0 4px 0;">
          Order #{orderNum}
        </h1>
        <p style="font-size: 13px; color: var(--color-muted); margin: 0;">Placed {formatDate(order.created_at)}</p>
      </div>
      <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
        <span style={`font-size: 12px; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: ${statusColor}; background: rgba(42,33,28,0.04); padding: 6px 14px; border-radius: 999px; border: 1px solid currentColor;`}>
          {statusLabel}
        </span>
        {receiptToken && (
          <a href={receiptUrl} style="font-size: 13px; font-weight: 600; color: var(--color-rose); text-decoration: none; padding: 6px 14px; border: 1.5px solid var(--color-rose); border-radius: 999px; white-space: nowrap;">
            Download receipt (PDF)
          </a>
        )}
      </div>
    </div>

    <!-- Status timeline (active orders) -->
    {!isCancelled && !isRefunded && (
      <div style="background: var(--color-charcoal); border-radius: 16px; border: 1px solid var(--color-slate); padding: 28px 28px 24px; margin-bottom: 20px;">
        <p style="font-size: 12px; font-weight: 700; color: var(--color-muted); letter-spacing: 0.06em; text-transform: uppercase; margin: 0 0 24px 0;">Order status</p>

        <!-- Timeline steps -->
        <div style="display: flex; align-items: flex-start; position: relative;">
          {steps.map((step, i) => (
            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; position: relative; z-index: 1;">
              {i > 0 && (
                <div style={`position: absolute; top: 13px; right: 50%; left: -50%; height: 2px; background: ${step.done ? 'var(--color-rose)' : 'var(--color-slate)'}; z-index: 0;`}></div>
              )}
              <div style={`width: 26px; height: 26px; border-radius: 50%; border: 2px solid ${step.done ? 'var(--color-rose)' : 'var(--color-slate)'}; background: ${step.done ? 'var(--color-rose)' : 'var(--color-charcoal)'}; display: flex; align-items: center; justify-content: center; margin-bottom: 8px; flex-shrink: 0; z-index: 1; position: relative;`}>
                {step.done && <span style="color: #F6F0E8; font-size: 11px; font-weight: 700;">✓</span>}
              </div>
              <span style={`font-size: 11px; font-weight: 600; letter-spacing: 0.03em; text-transform: uppercase; color: ${step.active ? 'var(--color-espresso)' : step.done ? 'var(--color-muted)' : 'var(--color-faint)'}; text-align: center; line-height: 1.3;`}>
                {step.label}
              </span>
            </div>
          ))}
        </div>

        <!-- Tracking info -->
        {order.tracking_number && carrierInfo && (
          <div style="margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--color-slate);">
            <div style="display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;">
              <div>
                <p style="font-size: 12px; color: var(--color-muted); margin: 0 0 3px 0;">
                  Carrier: <strong style="color: var(--color-espresso);">{carrierInfo.name}</strong>
                </p>
                <p style="font-size: 12px; color: var(--color-muted); margin: 0;">
                  Tracking: <span style="font-family: var(--font-family-mono); color: var(--color-espresso);">{order.tracking_number}</span>
                </p>
              </div>
              <a href={carrierInfo.url} target="_blank" rel="noopener noreferrer"
                style="display: inline-block; font-size: 14px; font-weight: 700; color: #F6F0E8; background: var(--color-rose); text-decoration: none; padding: 10px 22px; border-radius: 999px; white-space: nowrap;">
                Track with {carrierInfo.name}
              </a>
            </div>
          </div>
        )}

        <!-- ETA when not yet shipped -->
        {!order.tracking_number && (
          <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--color-slate);">
            <p style="font-size: 13px; color: var(--color-muted); margin: 0; line-height: 1.6;">
              <strong style="color: var(--color-espresso);">Estimated delivery:</strong> {etaStr}
              <span style="display: block; font-size: 12px; margin-top: 2px;">Tracking info will appear here once your order ships (typically 3–7 business days).</span>
            </p>
          </div>
        )}
      </div>
    )}

    <!-- Cancelled / Refunded notice -->
    {isCancelled && (
      <div style="background: rgba(178,58,51,0.06); border: 1px solid rgba(178,58,51,0.2); border-radius: 12px; padding: 18px 22px; margin-bottom: 20px;">
        <p style="font-size: 14px; font-weight: 600; color: #B23A33; margin: 0 0 4px 0;">This order was cancelled.</p>
        <p style="font-size: 13px; color: var(--color-muted); margin: 0; line-height: 1.6;">If you have questions, reach out to us below.</p>
      </div>
    )}
    {isRefunded && (
      <div style="background: rgba(178,58,51,0.06); border: 1px solid rgba(178,58,51,0.2); border-radius: 12px; padding: 18px 22px; margin-bottom: 20px;">
        <p style="font-size: 14px; font-weight: 600; color: #B23A33; margin: 0 0 4px 0;">Refund processed.</p>
        <p style="font-size: 13px; color: var(--color-muted); margin: 0; line-height: 1.6;">Your refund should appear on your original payment method within 3–7 business days.</p>
      </div>
    )}

    <div style="display: grid; grid-template-columns: 1fr; gap: 16px;">

      <!-- Line items -->
      <section style="background: var(--color-charcoal); border-radius: 16px; border: 1px solid var(--color-slate); padding: 24px 28px;">
        <h2 style="font-size: 15px; font-weight: 700; color: var(--color-espresso); margin: 0 0 18px 0; letter-spacing: -0.01em;">Items</h2>
        <div style="display: flex; flex-direction: column; gap: 14px;">
          {order.items.map((item) => (
            <div style="display: flex; gap: 14px; align-items: center; padding-bottom: 14px; border-bottom: 1px solid var(--color-slate);">
              {item.image
                ? <img src={item.image} alt={item.title} width="64" height="64"
                    style="width: 64px; height: 64px; object-fit: cover; border-radius: 10px; flex-shrink: 0;" />
                : <div style="width: 64px; height: 64px; background: var(--color-slate); border-radius: 10px; flex-shrink: 0;"></div>
              }
              <div style="flex: 1; min-width: 0;">
                <p style="font-size: 14px; font-weight: 600; color: var(--color-espresso); margin: 0 0 3px 0; line-height: 1.3;">{item.title}</p>
                {(item.color || item.size) && (
                  <p style="font-size: 12px; color: var(--color-muted); margin: 0 0 2px 0;">
                    {[item.color, item.size].filter(Boolean).join(' · ')}
                  </p>
                )}
                <p style="font-size: 12px; color: var(--color-muted); margin: 0;">Qty: {item.qty}</p>
              </div>
              <p style="font-size: 14px; font-weight: 600; color: var(--color-espresso); flex-shrink: 0; margin: 0;">
                {formatCurrency(item.unit_price * item.qty)}
              </p>
            </div>
          ))}
        </div>

        <!-- Totals -->
        <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--color-slate);">
          <div style="display: flex; justify-content: space-between; font-size: 13px; color: var(--color-muted); margin-bottom: 6px;">
            <span>Subtotal</span><span>{formatCurrency(order.subtotal)}</span>
          </div>
          <div style="display: flex; justify-content: space-between; font-size: 13px; color: var(--color-muted); margin-bottom: 6px;">
            <span>Shipping</span><span>{order.shipping === 0 ? 'Free' : formatCurrency(order.shipping)}</span>
          </div>
          <div style="display: flex; justify-content: space-between; font-size: 13px; color: var(--color-muted); margin-bottom: 14px;">
            <span>Tax</span><span>{formatCurrency(order.tax)}</span>
          </div>
          <div style="display: flex; justify-content: space-between; font-size: 17px; font-weight: 700; color: var(--color-espresso); padding-top: 10px; border-top: 1px solid var(--color-slate);">
            <span>Total</span>
            <span style="color: var(--color-rose);">{formatCurrency(order.total)}</span>
          </div>
        </div>
      </section>

      <!-- Shipping address -->
      {order.shipping_address && (
        <section style="background: var(--color-charcoal); border-radius: 16px; border: 1px solid var(--color-slate); padding: 24px 28px;">
          <h2 style="font-size: 15px; font-weight: 700; color: var(--color-espresso); margin: 0 0 14px 0; letter-spacing: -0.01em;">Shipping address</h2>
          <address style="font-style: normal; font-size: 14px; color: var(--color-muted); line-height: 1.8;">
            <strong style="color: var(--color-espresso);">{order.shipping_address.name}</strong><br />
            {order.shipping_address.line1}<br />
            {order.shipping_address.line2 && <>{order.shipping_address.line2}<br /></>}
            {order.shipping_address.city}, {order.shipping_address.state} {order.shipping_address.postal_code}<br />
            {order.shipping_address.country}
          </address>
        </section>
      )}

      <!-- Actions row -->
      <section style="display: flex; gap: 12px; flex-wrap: wrap;">
        <form method="POST" action="/api/cart/reorder" style="margin: 0;">
          <input type="hidden" name="order_id" value={order.id} />
          <button type="submit"
            style="font-size: 14px; font-weight: 700; color: #F6F0E8; background: var(--color-rose); border: none; border-radius: 999px; padding: 11px 24px; cursor: pointer; font-family: var(--font-family-display);">
            Reorder
          </button>
        </form>

        {receiptToken && (
          <a href={receiptUrl}
            style="font-size: 14px; font-weight: 700; color: var(--color-rose); border: 2px solid var(--color-rose); background: transparent; border-radius: 999px; padding: 9px 22px; text-decoration: none;">
            Download receipt (PDF)
          </a>
        )}
      </section>

    </div>

    <!-- Need help? -->
    <div style="margin-top: 28px; padding: 18px 22px; background: rgba(111,123,95,0.07); border-radius: 12px; border: 1px solid rgba(111,123,95,0.18);">
      <p style="font-size: 13px; color: var(--color-muted); margin: 0; line-height: 1.6;">
        <strong style="color: var(--color-espresso);">Need help?</strong>
        &nbsp;<a href={helpEmail} style="color: var(--color-sage); font-weight: 600; text-decoration: none;">Email us</a> with your order number <span style="font-family: var(--font-family-mono);">#{orderNum}</span> and we'll get back to you quickly.
      </p>
    </div>

  </div>
</BaseLayout>
