---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { listAddresses } from '../../lib/users-server';

if (!Astro.locals.user) {
  return Astro.redirect('/account/sign-in');
}

const user = Astro.locals.user;
const env = (Astro.locals as Record<string, unknown>).runtime?.env as
  | Record<string, unknown>
  | undefined;

const addresses = await listAddresses(user.id, env);
---

<BaseLayout
  title="Saved Addresses — Piece of Stass"
  description="Manage your saved shipping addresses."
  noindex
>
  <div style="max-width: 760px; margin: 0 auto; padding: 48px 16px 96px;">
    <!-- Breadcrumb -->
    <div style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--color-muted); margin-bottom: 32px;">
      <a href="/account" style="color: var(--color-muted); text-decoration: none;">Account</a>
      <span>›</span>
      <span style="color: var(--color-espresso);">Addresses</span>
    </div>

    <div style="display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 32px; flex-wrap: wrap;">
      <h1 style="font-family: var(--font-family-display); font-size: 28px; font-weight: 700; color: var(--color-espresso); letter-spacing: -0.03em;">
        Saved addresses
      </h1>
      <button
        id="add-btn"
        style="background: var(--color-lime); color: var(--color-cream); border: none; border-radius: var(--radius-pill); padding: 11px 20px; font-size: 13px; font-weight: 700; cursor: pointer; flex-shrink: 0; transition: opacity 150ms;"
        onclick="document.getElementById('add-form').style.display = 'block'; this.style.display = 'none';"
      >
        + Add address
      </button>
    </div>

    <!-- Add new address form (hidden by default) -->
    <div id="add-form" style="display: none; background: var(--color-charcoal); border-radius: var(--radius-xl); border: 1px solid var(--color-lime); padding: 32px; margin-bottom: 24px;">
      <h2 style="font-size: 16px; font-weight: 700; color: var(--color-espresso); margin-bottom: 24px;">New address</h2>
      <form id="new-address-form" novalidate>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
          <div>
            <label for="new_first_name" class="field-label">First name</label>
            <input id="new_first_name" name="first_name" type="text" required maxlength="100" class="field-input" autocomplete="given-name" />
          </div>
          <div>
            <label for="new_last_name" class="field-label">Last name</label>
            <input id="new_last_name" name="last_name" type="text" required maxlength="100" class="field-input" autocomplete="family-name" />
          </div>
        </div>
        <div style="margin-bottom: 16px;">
          <label for="new_address_1" class="field-label">Address line 1</label>
          <input id="new_address_1" name="address_1" type="text" required maxlength="200" class="field-input" autocomplete="address-line1" placeholder="123 Main St" />
        </div>
        <div style="margin-bottom: 16px;">
          <label for="new_address_2" class="field-label">Address line 2 <span style="color: var(--color-muted); font-weight: 400; text-transform: none;">(optional)</span></label>
          <input id="new_address_2" name="address_2" type="text" maxlength="200" class="field-input" autocomplete="address-line2" placeholder="Apt, suite, etc." />
        </div>
        <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 16px; margin-bottom: 16px;">
          <div>
            <label for="new_city" class="field-label">City</label>
            <input id="new_city" name="city" type="text" required maxlength="100" class="field-input" autocomplete="address-level2" />
          </div>
          <div>
            <label for="new_state" class="field-label">State</label>
            <input id="new_state" name="state" type="text" required maxlength="50" class="field-input" autocomplete="address-level1" />
          </div>
          <div>
            <label for="new_postal_code" class="field-label">ZIP</label>
            <input id="new_postal_code" name="postal_code" type="text" required maxlength="20" class="field-input" autocomplete="postal-code" />
          </div>
        </div>
        <div style="margin-bottom: 20px;">
          <label for="new_country" class="field-label">Country (2-letter code)</label>
          <input id="new_country" name="country" type="text" required maxlength="2" class="field-input" autocomplete="country" placeholder="US" value="US" style="text-transform: uppercase;" />
        </div>
        <label style="display: flex; align-items: center; gap: 10px; margin-bottom: 24px; cursor: pointer;">
          <input id="new_is_default" name="is_default" type="checkbox" style="width:16px; height:16px; accent-color: var(--color-lime);" />
          <span style="font-size: 14px; color: var(--color-espresso);">Set as default address</span>
        </label>

        <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
          <button type="submit" style="background: var(--color-lime); color: var(--color-cream); border: none; border-radius: var(--radius-pill); padding: 12px 24px; font-size: 14px; font-weight: 700; cursor: pointer;">Save address</button>
          <button type="button" onclick="document.getElementById('add-form').style.display='none'; document.getElementById('add-btn').style.display='inline-flex';" style="background: none; border: 1px solid var(--color-slate); border-radius: var(--radius-pill); padding: 12px 24px; font-size: 14px; color: var(--color-muted); cursor: pointer;">Cancel</button>
          <span id="new-addr-status" style="font-size: 13px; color: var(--color-muted);"></span>
        </div>
      </form>
    </div>

    <!-- Address list -->
    <div id="address-list">
      {addresses.length === 0 ? (
        <div style="text-align: center; padding: 60px 20px; background: var(--color-charcoal); border-radius: var(--radius-xl); border: 1px solid var(--color-slate);">
          <div style="font-size: 40px; margin-bottom: 12px; opacity: 0.4;">📍</div>
          <p style="font-size: 15px; color: var(--color-muted);">No saved addresses yet.</p>
        </div>
      ) : (
        <div style="display: grid; gap: 16px;">
          {addresses.map((addr) => (
            <div
              data-address-id={addr.id}
              style={`background: var(--color-charcoal); border-radius: var(--radius-lg); border: 1px solid ${addr.is_default ? 'var(--color-lime)' : 'var(--color-slate)'}; padding: 24px;`}
            >
              <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 12px; flex-wrap: wrap;">
                <div>
                  {addr.is_default && (
                    <span style="display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: var(--color-lime); background: rgba(178,94,107,0.1); padding: 3px 10px; border-radius: var(--radius-pill); margin-bottom: 6px;">
                      Default
                    </span>
                  )}
                  {addr.label && (
                    <div style="font-size: 14px; font-weight: 700; color: var(--color-espresso); margin-bottom: 2px;">{addr.label}</div>
                  )}
                  <address style="font-style: normal; font-size: 14px; color: var(--color-muted); line-height: 1.7;">
                    {addr.first_name} {addr.last_name}<br />
                    {addr.address_1}<br />
                    {addr.address_2 && <>{addr.address_2}<br /></>}
                    {addr.city}, {addr.state} {addr.postal_code}<br />
                    {addr.country}
                  </address>
                </div>
                <button
                  class="delete-addr-btn"
                  data-id={addr.id}
                  style="background: none; border: 1px solid var(--color-slate); border-radius: var(--radius-md); padding: 6px 12px; font-size: 12px; color: var(--color-muted); cursor: pointer; flex-shrink: 0; transition: color 150ms, border-color 150ms;"
                  onmouseover="this.style.color='var(--color-error)'; this.style.borderColor='var(--color-error)'"
                  onmouseout="this.style.color='var(--color-muted)'; this.style.borderColor='var(--color-slate)'"
                >
                  Delete
                </button>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .field-label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-espresso);
    margin-bottom: 8px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .field-input {
    width: 100%;
    background: var(--color-surface);
    border: 1.5px solid var(--color-slate);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    font-size: 15px;
    color: var(--color-espresso);
    outline: none;
    transition: border-color 150ms;
    box-sizing: border-box;
    font-family: inherit;
  }
  .field-input:focus {
    border-color: var(--color-lime);
  }
</style>

<script>
  // New address submission
  const newForm = document.getElementById('new-address-form') as HTMLFormElement;
  const newStatus = document.getElementById('new-addr-status') as HTMLSpanElement;

  newForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(newForm);
    const payload: Record<string, unknown> = {
      first_name: fd.get('first_name'),
      last_name: fd.get('last_name'),
      address_1: fd.get('address_1'),
      address_2: fd.get('address_2') || undefined,
      city: fd.get('city'),
      state: fd.get('state'),
      postal_code: fd.get('postal_code'),
      country: String(fd.get('country')).toUpperCase(),
      is_default: (document.getElementById('new_is_default') as HTMLInputElement).checked,
    };

    newStatus.textContent = 'Saving…';
    newStatus.style.color = 'var(--color-muted)';

    try {
      const res = await fetch('/api/account/addresses', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        window.location.reload();
      } else {
        const err = await res.json() as Record<string, string>;
        newStatus.textContent = err.error ?? 'Failed to save';
        newStatus.style.color = 'var(--color-error)';
      }
    } catch {
      newStatus.textContent = 'Network error';
      newStatus.style.color = 'var(--color-error)';
    }
  });

  // Delete address
  document.querySelectorAll<HTMLButtonElement>('.delete-addr-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id;
      if (!id || !confirm('Delete this address?')) return;
      try {
        const res = await fetch(`/api/account/addresses/${id}`, { method: 'DELETE' });
        if (res.ok) {
          const card = document.querySelector(`[data-address-id="${id}"]`);
          card?.remove();
        }
      } catch {
        alert('Failed to delete address');
      }
    });
  });
</script>
