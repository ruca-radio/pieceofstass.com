---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';

// If already signed in, redirect to account
if (Astro.locals.user) {
  return Astro.redirect('/account');
}

const errorMessages: Record<string, string> = {
  missing_token: 'Sign-in link is missing. Please request a new one.',
  invalid_token: 'Sign-in link is invalid or has expired. Please request a new one.',
};

const errorParam = Astro.url.searchParams.get('error') ?? '';
const errorMessage = errorMessages[errorParam] ?? '';
---

<BaseLayout
  title="Sign In — Piece of Stass"
  description="Sign in to your Piece of Stass account with a magic link — no password needed."
  noindex
>
  <section style="min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 64px 16px;">
    <div style="width: 100%; max-width: 440px;">

      <!-- Logo mark -->
      <div style="text-align: center; margin-bottom: 40px;">
        <a href="/" style="display: inline-flex; flex-direction: column; align-items: center; gap: 12px; text-decoration: none;">
          <svg width="48" height="48" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <rect width="32" height="32" rx="6" fill="var(--color-lime)" />
            <path d="M9 7h8c2.761 0 5 2.239 5 5s-2.239 5-5 5H9V7z" fill="var(--color-cream)" />
            <path d="M9 17v8" stroke="var(--color-cream)" stroke-width="3" stroke-linecap="round" />
          </svg>
          <span style="font-family: var(--font-family-display); font-weight: 700; font-size: 20px; color: var(--color-espresso); letter-spacing: -0.02em;">STASS</span>
        </a>
      </div>

      <!-- Card -->
      <div style="background: var(--color-charcoal); border-radius: var(--radius-xl); padding: 40px 36px; border: 1px solid var(--color-slate);">
        <h1 style="font-family: var(--font-family-display); font-size: 24px; font-weight: 700; color: var(--color-espresso); margin-bottom: 8px; letter-spacing: -0.02em;">
          Sign in
        </h1>
        <p style="font-size: 15px; color: var(--color-muted); margin-bottom: 32px; line-height: 1.6;">
          Enter your email and we'll send you a magic link. No password needed.
        </p>

        {errorMessage && (
          <div role="alert" style="background: rgba(229,72,77,0.12); border: 1px solid rgba(229,72,77,0.3); border-radius: var(--radius-md); padding: 12px 16px; margin-bottom: 24px; font-size: 14px; color: #E5484D;">
            {errorMessage}
          </div>
        )}

        <!-- Form (handled by JS below) -->
        <form id="magic-link-form" novalidate>
          <div style="margin-bottom: 20px;">
            <label for="email" style="display: block; font-size: 13px; font-weight: 600; color: var(--color-espresso); margin-bottom: 8px; letter-spacing: 0.02em; text-transform: uppercase;">
              Email address
            </label>
            <input
              id="email"
              type="email"
              name="email"
              placeholder="you@example.com"
              autocomplete="email"
              required
              style="width: 100%; background: var(--color-surface); border: 1.5px solid var(--color-slate); border-radius: var(--radius-md); padding: 12px 16px; font-size: 15px; color: var(--color-espresso); outline: none; transition: border-color 150ms; box-sizing: border-box;"
              onfocus="this.style.borderColor='var(--color-lime)'"
              onblur="this.style.borderColor='var(--color-slate)'"
            />
          </div>

          <button
            type="submit"
            id="submit-btn"
            style="width: 100%; background: var(--color-lime); color: var(--color-cream); border: none; border-radius: var(--radius-pill); padding: 14px 24px; font-size: 15px; font-weight: 700; cursor: pointer; transition: opacity 200ms; letter-spacing: -0.01em;"
          >
            Send magic link
          </button>
        </form>

        <!-- Success state (hidden initially) -->
        <div id="success-state" style="display: none; text-align: center; padding: 8px 0;">
          <div style="width: 56px; height: 56px; background: rgba(178,94,107,0.12); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-size: 28px;">
            ✉️
          </div>
          <h2 style="font-family: var(--font-family-display); font-size: 20px; font-weight: 700; color: var(--color-espresso); margin-bottom: 8px; letter-spacing: -0.02em;">
            Check your inbox
          </h2>
          <p style="font-size: 15px; color: var(--color-muted); line-height: 1.6;">
            We sent a magic link to <strong id="sent-email" style="color: var(--color-espresso);"></strong>.
            It expires in 15 minutes.
          </p>
        </div>

        <div id="error-msg" role="alert" style="display: none; background: rgba(229,72,77,0.12); border: 1px solid rgba(229,72,77,0.3); border-radius: var(--radius-md); padding: 12px 16px; margin-top: 16px; font-size: 14px; color: #E5484D;"></div>
      </div>

      <p style="text-align: center; font-size: 13px; color: var(--color-muted); margin-top: 24px; line-height: 1.6;">
        New here? Your account is created automatically on first sign-in.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('magic-link-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successState = document.getElementById('success-state') as HTMLDivElement;
  const sentEmailEl = document.getElementById('sent-email') as HTMLSpanElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    if (!email) return;

    btn.disabled = true;
    btn.textContent = 'Sending…';
    errorMsg.style.display = 'none';

    try {
      const res = await fetch('/api/auth/magic-link', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      const data = await res.json() as Record<string, unknown>;

      if (!res.ok) {
        errorMsg.textContent = (data.error as string) ?? 'Something went wrong. Please try again.';
        errorMsg.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Send magic link';
        return;
      }

      // Show success state
      form.style.display = 'none';
      sentEmailEl.textContent = email;
      successState.style.display = 'block';

    } catch {
      errorMsg.textContent = 'Network error. Please try again.';
      errorMsg.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Send magic link';
    }
  });
</script>
