---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTrendingProducts } from '../lib/products';
import ProductCard from '../components/islands/ProductCard';

const trending = getTrendingProducts(4);
---

<BaseLayout
  title="Page not found — Piece of Stass"
  description="We couldn't find that page. But we found some great products."
  noindex={true}
>
  <div style="max-width: 1280px; margin: 0 auto; padding: 80px 16px; text-align: center;">
    <p style="font-family: var(--font-family-mono); font-size: 64px; color: var(--color-lime); font-weight: 400; margin: 0 0 8px; line-height: 1;">404</p>
    <h1 style="font-family: var(--font-family-display); font-weight: 700; font-size: 30px; letter-spacing: -0.02em; margin: 0 0 12px; color: var(--color-espresso);">Not in the stash</h1>
    <p style="color: var(--color-muted); font-size: 15px; max-width: 380px; margin: 0 auto 32px; line-height: 1.6;">That page doesn't exist. But these finds do — and they're better anyway.</p>
    <a href="/shop" style="background: var(--color-lime); color: var(--color-cream); border-radius: 999px; padding: 14px 32px; font-family: var(--font-family-display); font-weight: 700; font-size: 15px; text-decoration: none; display: inline-block; margin-bottom: 64px;">
      Raid the stash
    </a>

    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; max-width: 800px; margin: 0 auto;" class="four-oh-four-grid">
      {trending.map((p) => (
        <ProductCard product={p} client:visible />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  @media (min-width: 768px) {
    .four-oh-four-grid { grid-template-columns: repeat(4, 1fr) !important; }
  }
</style>
