---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/admin-auth';
import { listOrders, kpiSummary, getOrdersKVFromEnv } from '../../lib/orders-server';
import { getAllSuppliers, getSupplierEmail } from '../../lib/supplier-routing';

const env = await requireAdmin(Astro);
if (!env) return Astro.redirect('/admin/sign-in?error=session');

const runtimeEnv = ((Astro.locals as Record<string, unknown>)?.runtime as Record<string, unknown>)?.env as Record<string, string> | undefined;
const kv = getOrdersKVFromEnv(runtimeEnv);

const suppliers = getAllSuppliers();
const { orders: allOrders } = await listOrders(kv, { status: 'all', limit: 1000 });

const now = Date.now();
const monthMs = now - 30 * 24 * 60 * 60 * 1000;

// Compute per-supplier stats
const supplierStats = suppliers.map((s) => {
  // Map supplier_id to category key
  const supplierOrders = allOrders.filter(o =>
    o.items.some(i => i.category === s.supplier_id || i.supplier_sku?.startsWith(s.supplier_id.toUpperCase().slice(0, 4)))
  );

  // Approximate by category match
  const categoryKey = Object.entries({ footwear: 'chenyico', watches: '117034687', bags: '3293950449', men: 'miao2017', women: 'ypd2023', kids: '775180006', fragrance: 'jmshop88', tech: 'xtd8288' }).find(([_, v]) => v === s.supplier_id)?.[0] ?? '';

  const catOrders = allOrders.filter(o => o.items.some(i => i.category === categoryKey));
  const pendingOrders = catOrders.filter(o => o.status === 'payment_captured' || o.status === 'sent_to_supplier');
  const monthOrders = catOrders.filter(o => new Date(o.created_at).getTime() >= monthMs && !['cancelled', 'refunded'].includes(o.status));
  const monthRevenue = monthOrders.reduce((sum, o) => sum + o.total, 0);
  const activeProducts = allOrders.flatMap(o => o.items).filter(i => i.category === categoryKey).length;

  const supplierEmailAddr = runtimeEnv ? getSupplierEmail(s, runtimeEnv) : `[Set ${s.supplier_email_env_key}]`;

  return {
    ...s,
    email: supplierEmailAddr,
    category: categoryKey,
    active_products: new Set(allOrders.flatMap(o => o.items.filter(i => i.category === categoryKey).map(i => i.product_id))).size,
    pending_orders: pendingOrders.length,
    month_revenue: monthRevenue,
    total_orders: catOrders.length,
  };
});

function formatMoney(n: number) {
  return `$${n.toLocaleString('en-US', { minimumFractionDigits: 0 })}`;
}
---
<AdminLayout title="Suppliers" activeNav="suppliers">

  <div class="adm-card" style="margin-bottom:20px;background:rgba(198,255,58,0.04);border-color:rgba(198,255,58,0.15);">
    <div style="font-size:12px;color:var(--adm-muted);line-height:1.6;">
      Supplier contacts and routing from <code class="adm-mono">/src/lib/supplier-routing.ts</code>.
      To update supplier emails, set the <code class="adm-mono">SUPPLIER_EMAIL_*</code> env vars in your Cloudflare dashboard or <code class="adm-mono">wrangler.toml</code>.
    </div>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(440px,1fr));gap:16px;">
    {supplierStats.map((s) => (
      <div class="adm-card">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px;">
          <div>
            <div style="font-weight:700;font-size:14px;margin-bottom:2px;">{s.supplier_name}</div>
            <div style="font-size:11px;color:var(--adm-muted);font-family:var(--adm-mono);">{s.supplier_id}</div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">
            <span class="adm-badge adm-badge-active" style="font-size:10px;">{s.category}</span>
            <span style="font-size:11px;color:var(--adm-muted);">{s.ship_from} · {s.est_days_min}–{s.est_days_max}d</span>
          </div>
        </div>

        <!-- Stats row -->
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:12px;">
          <div style="background:var(--adm-surface2);border-radius:6px;padding:8px 10px;text-align:center;">
            <div style="font-size:18px;font-weight:700;">{s.pending_orders}</div>
            <div style="font-size:10px;color:var(--adm-muted);">Pending</div>
          </div>
          <div style="background:var(--adm-surface2);border-radius:6px;padding:8px 10px;text-align:center;">
            <div style="font-size:18px;font-weight:700;">{s.total_orders}</div>
            <div style="font-size:10px;color:var(--adm-muted);">Total Orders</div>
          </div>
          <div style="background:var(--adm-surface2);border-radius:6px;padding:8px 10px;text-align:center;">
            <div style="font-size:16px;font-weight:700;">{formatMoney(s.month_revenue)}</div>
            <div style="font-size:10px;color:var(--adm-muted);">30d Revenue</div>
          </div>
        </div>

        <!-- Details -->
        <div style="display:flex;flex-direction:column;gap:5px;font-size:12px;">
          <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--adm-muted);">Platform</span>
            <span>{s.platform}</span>
          </div>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="color:var(--adm-muted);">Contact Email</span>
            <div style="display:flex;align-items:center;gap:6px;">
              <span class="adm-mono" style="font-size:11px;color:{s.email.startsWith('[Set') ? 'var(--adm-error)' : 'var(--adm-text)'};">
                {s.email.startsWith('[Set') ? '⚠ Not configured' : s.email}
              </span>
              {!s.email.startsWith('[Set') && (
                <button
                  type="button"
                  class="adm-btn adm-btn-secondary"
                  style="padding:2px 6px;font-size:10px;"
                  onclick={`navigator.clipboard.writeText('${s.email}').then(()=>window.adminToast('Email copied','success'))`}
                >Copy</button>
              )}
            </div>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <span style="color:var(--adm-muted);">Invoice Currency</span>
            <span>{s.invoice_currency}</span>
          </div>
        </div>

        {s.notes && (
          <div style="margin-top:10px;padding:8px 10px;background:rgba(138,138,142,0.08);border-radius:5px;font-size:11px;color:var(--adm-muted);line-height:1.5;">
            {s.notes}
          </div>
        )}

        <!-- Actions -->
        <div style="display:flex;gap:8px;margin-top:12px;">
          <a href={`/admin/orders?supplier=${s.category}`} class="adm-btn adm-btn-secondary" style="font-size:11px;padding:4px 10px;">
            View Orders ({s.pending_orders} pending)
          </a>
          {s.email && !s.email.startsWith('[Set') && (
            <a href={`mailto:${s.email}`} class="adm-btn adm-btn-secondary" style="font-size:11px;padding:4px 10px;">
              Email ↗
            </a>
          )}
        </div>
      </div>
    ))}
  </div>

</AdminLayout>
