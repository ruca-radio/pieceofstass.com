---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../../lib/admin-auth';
import { listOrders, getOrdersKVFromEnv } from '../../../lib/orders-server';
import type { OrderStatus } from '../../../lib/orders-server';

const env = await requireAdmin(Astro);
if (!env) return Astro.redirect('/admin/sign-in?error=session');

const runtimeEnv = ((Astro.locals as Record<string, unknown>)?.runtime as Record<string, unknown>)?.env as Record<string, unknown> | undefined;
const kv = getOrdersKVFromEnv(runtimeEnv);

const url = Astro.url;
const statusFilter = (url.searchParams.get('status') ?? 'all') as OrderStatus | 'all';
const searchQuery = url.searchParams.get('q') ?? '';
const dateFrom = url.searchParams.get('from') ?? '';
const dateTo = url.searchParams.get('to') ?? '';
const page = Math.max(1, parseInt(url.searchParams.get('page') ?? '1', 10));
const limit = 25;
const offset = (page - 1) * limit;

const { orders, total } = await listOrders(kv, {
  status: statusFilter,
  search: searchQuery || undefined,
  date_from: dateFrom || undefined,
  date_to: dateTo || undefined,
  limit,
  offset,
});

const totalPages = Math.ceil(total / limit);

function formatMoney(n: number) {
  return `$${n.toLocaleString('en-US', { minimumFractionDigits: 0 })}`;
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric',
    hour: '2-digit', minute: '2-digit'
  });
}

const statusBadgeClass: Record<string, string> = {
  pending: 'adm-badge-pending',
  payment_captured: 'adm-badge-captured',
  sent_to_supplier: 'adm-badge-supplier',
  shipped: 'adm-badge-shipped',
  delivered: 'adm-badge-delivered',
  refunded: 'adm-badge-refunded',
  cancelled: 'adm-badge-cancelled',
};

const statusLabel: Record<string, string> = {
  all: 'All',
  pending: 'Pending',
  payment_captured: 'Paid',
  sent_to_supplier: 'Sent to Supplier',
  shipped: 'Shipped',
  delivered: 'Delivered',
  refunded: 'Refunded',
  cancelled: 'Cancelled',
};

const statusOptions = ['all', 'pending', 'payment_captured', 'sent_to_supplier', 'shipped', 'delivered', 'refunded', 'cancelled'];
---
<AdminLayout title="Orders" activeNav="orders">

  <!-- Filters -->
  <form method="GET" class="adm-filters">
    <div>
      <label class="adm-label">Status</label>
      <select name="status" class="adm-select" style="width:160px;">
        {statusOptions.map((s) => (
          <option value={s} selected={statusFilter === s}>{statusLabel[s]}</option>
        ))}
      </select>
    </div>
    <div>
      <label class="adm-label">Search (email / order ID)</label>
      <input type="text" name="q" value={searchQuery} class="adm-input" placeholder="Search..." style="width:220px;" />
    </div>
    <div>
      <label class="adm-label">From</label>
      <input type="date" name="from" value={dateFrom} class="adm-input" style="width:140px;" />
    </div>
    <div>
      <label class="adm-label">To</label>
      <input type="date" name="to" value={dateTo} class="adm-input" style="width:140px;" />
    </div>
    <div style="padding-top:18px;">
      <button type="submit" class="adm-btn adm-btn-primary">Filter</button>
    </div>
    {(statusFilter !== 'all' || searchQuery || dateFrom || dateTo) && (
      <div style="padding-top:18px;">
        <a href="/admin/orders" class="adm-btn adm-btn-secondary">Clear</a>
      </div>
    )}
  </form>

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
    <div style="font-size:13px;color:var(--adm-muted);">
      {total} order{total !== 1 ? 's' : ''}
      {statusFilter !== 'all' ? ` · ${statusLabel[statusFilter]}` : ''}
    </div>
  </div>

  <div class="adm-card" style="padding:0;overflow:hidden;">
    {orders.length === 0 ? (
      <div style="padding:32px;text-align:center;color:var(--adm-muted);">No orders match the current filters.</div>
    ) : (
      <table class="adm-table">
        <thead>
          <tr>
            <th>Order ID</th>
            <th>Date</th>
            <th>Customer</th>
            <th>Items</th>
            <th>Total</th>
            <th>Status</th>
            <th>Supplier</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {orders.map((o) => (
            <tr>
              <td>
                <a href={`/admin/orders/${o.id}`} class="adm-mono" style="font-size:11px;">{o.id}</a>
              </td>
              <td class="adm-mono" style="font-size:11px;color:var(--adm-muted);white-space:nowrap;">{formatDate(o.created_at)}</td>
              <td>
                <div style="font-size:13px;">{o.customer_name ?? '—'}</div>
                <div style="font-size:11px;color:var(--adm-muted);">{o.customer_email}</div>
              </td>
              <td style="color:var(--adm-muted);font-size:12px;">{o.items.length} item{o.items.length !== 1 ? 's' : ''}</td>
              <td class="adm-mono" style="font-size:13px;">{formatMoney(o.total)}</td>
              <td>
                <span class={`adm-badge ${statusBadgeClass[o.status] ?? ''}`}>
                  {statusLabel[o.status] ?? o.status}
                </span>
              </td>
              <td style="font-size:12px;color:var(--adm-muted);">
                {o.supplier_status ?? '—'}
              </td>
              <td>
                <a href={`/admin/orders/${o.id}`} class="adm-btn adm-btn-secondary" style="padding:4px 10px;font-size:12px;">View →</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <!-- Pagination -->
  {totalPages > 1 && (
    <div style="display:flex;gap:8px;align-items:center;margin-top:16px;justify-content:flex-end;">
      {page > 1 && (
        <a href={`/admin/orders?status=${statusFilter}&q=${searchQuery}&from=${dateFrom}&to=${dateTo}&page=${page - 1}`}
           class="adm-btn adm-btn-secondary" style="padding:6px 12px;font-size:12px;">← Prev</a>
      )}
      <span style="font-size:12px;color:var(--adm-muted);">Page {page} of {totalPages}</span>
      {page < totalPages && (
        <a href={`/admin/orders?status=${statusFilter}&q=${searchQuery}&from=${dateFrom}&to=${dateTo}&page=${page + 1}`}
           class="adm-btn adm-btn-secondary" style="padding:6px 12px;font-size:12px;">Next →</a>
      )}
    </div>
  )}

</AdminLayout>
