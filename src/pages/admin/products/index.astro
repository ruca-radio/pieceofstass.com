---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../../lib/admin-auth';
import { listProductsWithOverrides } from '../../../lib/products-server';
import { getOrdersKVFromEnv } from '../../../lib/orders-server';

const env = await requireAdmin(Astro);
if (!env) return Astro.redirect('/admin/sign-in?error=session');

const runtimeEnv = ((Astro.locals as Record<string, unknown>)?.runtime as Record<string, unknown>)?.env as Record<string, unknown> | undefined;
const kv = getOrdersKVFromEnv(runtimeEnv);

const products = await listProductsWithOverrides(kv);

const url = Astro.url;
const searchQuery = url.searchParams.get('q') ?? '';
const categoryFilter = url.searchParams.get('category') ?? 'all';
const statusFilter = url.searchParams.get('status') ?? 'all';
const priceMin = url.searchParams.get('pmin') ? parseFloat(url.searchParams.get('pmin')!) : undefined;
const priceMax = url.searchParams.get('pmax') ? parseFloat(url.searchParams.get('pmax')!) : undefined;

let filtered = products;
if (searchQuery) {
  const q = searchQuery.toLowerCase();
  filtered = filtered.filter(
    (p) => p.title.toLowerCase().includes(q) || p.id.toLowerCase().includes(q)
  );
}
if (categoryFilter !== 'all') {
  filtered = filtered.filter((p) => p.category === categoryFilter);
}
if (statusFilter !== 'all') {
  filtered = filtered.filter((p) => p.status === statusFilter);
}
if (priceMin !== undefined) {
  filtered = filtered.filter(p => p.price >= priceMin);
}
if (priceMax !== undefined) {
  filtered = filtered.filter(p => p.price <= priceMax);
}

const categories = [...new Set(products.map((p) => p.category))].sort();
---
<AdminLayout title="Products" activeNav="products">

  <div class="adm-filters">
    <form method="GET" style="display:contents;">
      <div>
        <label class="adm-label">Search</label>
        <input type="text" name="q" value={searchQuery} class="adm-input" placeholder="Title or ID…" style="width:200px;" />
      </div>
      <div>
        <label class="adm-label">Category</label>
        <select name="category" class="adm-select" style="width:140px;">
          <option value="all">All Categories</option>
          {categories.map((c) => (
            <option value={c} selected={categoryFilter === c}>{c}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="adm-label">Status</label>
        <select name="status" class="adm-select" style="width:110px;">
          <option value="all">All</option>
          <option value="active" selected={statusFilter === 'active'}>Active</option>
          <option value="draft" selected={statusFilter === 'draft'}>Draft</option>
        </select>
      </div>
      <div>
        <label class="adm-label">Price $Min</label>
        <input type="number" name="pmin" value={priceMin ?? ''} class="adm-input" style="width:80px;" min="0" step="1" />
      </div>
      <div>
        <label class="adm-label">$Max</label>
        <input type="number" name="pmax" value={priceMax ?? ''} class="adm-input" style="width:80px;" min="0" step="1" />
      </div>
      <div style="padding-top:18px;">
        <button type="submit" class="adm-btn adm-btn-primary">Filter</button>
      </div>
      {(searchQuery || categoryFilter !== 'all' || statusFilter !== 'all' || priceMin !== undefined || priceMax !== undefined) && (
        <div style="padding-top:18px;">
          <a href="/admin/products" class="adm-btn adm-btn-secondary">Clear</a>
        </div>
      )}
    </form>
  </div>

  <!-- Bulk toolbar -->
  <div id="bulk-toolbar" style="display:none;align-items:center;gap:8px;margin-bottom:12px;padding:10px 12px;background:var(--adm-surface2);border:1px solid var(--adm-border);border-radius:8px;">
    <span id="bulk-count" style="font-size:13px;color:var(--adm-muted);margin-right:4px;">0 selected</span>
    <button type="button" class="adm-btn adm-btn-secondary" style="font-size:12px;" onclick="bulkSetStatus('active')">Set Active</button>
    <button type="button" class="adm-btn adm-btn-secondary" style="font-size:12px;" onclick="bulkSetStatus('draft')">Set Draft</button>
    <button type="button" class="adm-btn adm-btn-secondary" style="font-size:12px;" onclick="promptBulkDiscount()">Apply Discount %</button>
    <button type="button" class="adm-btn adm-btn-secondary" style="font-size:12px;" onclick="exportSelectedCSV()">Export CSV</button>
    <button type="button" class="adm-btn adm-btn-secondary" style="font-size:12px;margin-left:auto;" onclick="clearSelection()">Deselect</button>
  </div>

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
    <div style="font-size:13px;color:var(--adm-muted);">
      {filtered.length} product{filtered.length !== 1 ? 's' : ''}
      {filtered.filter(p => p.status === 'draft').length > 0 && (
        <span> · {filtered.filter(p => p.status === 'draft').length} draft</span>
      )}
    </div>
    <a href="/api/admin/products/export-csv" class="adm-btn adm-btn-secondary" style="font-size:12px;">↓ Export All CSV</a>
  </div>

  <div class="adm-card" style="padding:0;overflow:hidden;">
    <table class="adm-table" id="products-table">
      <thead>
        <tr>
          <th style="width:36px;">
            <input type="checkbox" class="adm-checkbox" id="select-all" onchange="toggleSelectAll(this)" />
          </th>
          <th>Image</th>
          <th>Title</th>
          <th>Category</th>
          <th>Price</th>
          <th>Compare at</th>
          <th>Status</th>
          <th>Override</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {filtered.map((p) => {
          // Check if override exists (non-empty object)
          const hasOverride = false; // We don't have this info at render time without another KV call
          return (
            <tr data-product-id={p.id}>
              <td style="padding:8px 12px;">
                <input type="checkbox" class="adm-checkbox product-checkbox" value={p.id} onchange="updateBulkToolbar()" />
              </td>
              <td style="width:52px;padding:8px 8px 8px 12px;">
                {p.images[0] ? (
                  <img src={p.images[0]} alt="" style="width:44px;height:44px;object-fit:cover;border-radius:4px;display:block;" loading="lazy" />
                ) : (
                  <div style="width:44px;height:44px;border-radius:4px;background:var(--adm-surface2);"></div>
                )}
              </td>
              <td>
                <a href={`/admin/products/${p.id}`} style="font-size:13px;font-weight:500;">{p.title}</a>
                <div class="adm-mono" style="font-size:10px;color:var(--adm-muted);margin-top:2px;">{p.id.slice(0,30)}</div>
              </td>
              <td style="font-size:12px;color:var(--adm-muted);">{p.category}</td>
              <td class="adm-mono" style="font-size:13px;">${p.price}</td>
              <td class="adm-mono" style="font-size:12px;color:var(--adm-muted);">
                {p.compare_at_price ? `$${p.compare_at_price}` : '—'}
              </td>
              <td>
                <span class={`adm-badge ${p.status === 'active' ? 'adm-badge-active' : 'adm-badge-draft'}`}>
                  {p.status}
                </span>
              </td>
              <td style="font-size:11px;color:var(--adm-muted);">
                —
              </td>
              <td>
                <a href={`/admin/products/${p.id}`} class="adm-btn adm-btn-secondary" style="padding:4px 10px;font-size:12px;">Edit →</a>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

</AdminLayout>

<script>
  function getSelectedIds() {
    return [...document.querySelectorAll('.product-checkbox:checked')].map(el => el.value);
  }
  function updateBulkToolbar() {
    const ids = getSelectedIds();
    const toolbar = document.getElementById('bulk-toolbar');
    const countEl = document.getElementById('bulk-count');
    if (toolbar) toolbar.style.display = ids.length > 0 ? 'flex' : 'none';
    if (countEl) countEl.textContent = `${ids.length} selected`;
    const all = document.querySelectorAll('.product-checkbox');
    const selectAll = document.getElementById('select-all');
    if (selectAll) {
      selectAll.indeterminate = ids.length > 0 && ids.length < all.length;
      selectAll.checked = ids.length === all.length && all.length > 0;
    }
  }
  function toggleSelectAll(cb) {
    document.querySelectorAll('.product-checkbox').forEach(el => el.checked = cb.checked);
    updateBulkToolbar();
  }
  function clearSelection() {
    document.querySelectorAll('.product-checkbox, #select-all').forEach(el => el.checked = false);
    updateBulkToolbar();
  }

  async function bulkSetStatus(status) {
    const ids = getSelectedIds();
    if (!ids.length) return;
    if (!confirm(`Set ${ids.length} product(s) to "${status}"?`)) return;
    let ok = 0, fail = 0;
    for (const id of ids) {
      try {
        const r = await fetch(`/api/admin/products/${id}`, {
          method: 'PATCH',
          headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ status }),
        });
        if ((await r.json()).ok) ok++; else fail++;
      } catch { fail++; }
    }
    window.adminToast(`${ok} updated${fail ? `, ${fail} failed` : ''}`, fail > 0 ? 'warning' : 'success');
    if (ok > 0) setTimeout(() => location.reload(), 800);
  }

  function promptBulkDiscount() {
    const ids = getSelectedIds();
    if (!ids.length) return;
    const pct = parseFloat(prompt('Apply discount % off current price (e.g. 20 for 20% off):') ?? '');
    if (isNaN(pct) || pct <= 0 || pct >= 100) { window.adminToast('Invalid percentage', 'warning'); return; }
    if (!confirm(`Apply ${pct}% discount to ${ids.length} products? This reduces their prices.`)) return;

    // Get current prices from table and calculate new prices
    let updates = [];
    ids.forEach(id => {
      const row = document.querySelector(`tr[data-product-id="${id}"]`);
      if (!row) return;
      const priceCell = row.querySelector('td:nth-child(5)');
      const currentPrice = parseFloat(priceCell?.textContent?.replace('$','') ?? '0');
      if (currentPrice > 0) {
        updates.push({ id, price: Math.round(currentPrice * (1 - pct/100)), compare_at_price: currentPrice });
      }
    });

    Promise.all(updates.map(u => fetch(`/api/admin/products/${u.id}`, {
      method: 'PATCH',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ price: u.price, compare_at_price: u.compare_at_price }),
    }))).then(results => {
      window.adminToast(`${pct}% discount applied to ${updates.length} products`, 'success');
      setTimeout(() => location.reload(), 800);
    });
  }

  function exportSelectedCSV() {
    const ids = getSelectedIds();
    if (!ids.length) { window.adminToast('No products selected', 'info'); return; }
    const rows = [['Product ID','Title','Category','Price','Compare At','Status']];
    ids.forEach(id => {
      const row = document.querySelector(`tr[data-product-id="${id}"]`);
      if (!row) return;
      const cells = row.querySelectorAll('td');
      rows.push([
        id,
        cells[2]?.querySelector('a')?.textContent?.trim() ?? '',
        cells[3]?.textContent?.trim() ?? '',
        cells[4]?.textContent?.trim() ?? '',
        cells[5]?.textContent?.trim() ?? '',
        cells[6]?.textContent?.trim() ?? '',
      ]);
    });
    const csv = rows.map(r => r.map(v => `"${v.replace(/"/g,'""')}"`).join(',')).join('\n');
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([csv], {type:'text/csv'}));
    a.download = `products-export-${Date.now()}.csv`;
    a.click();
    window.adminToast(`Exported ${ids.length} products`, 'success');
  }
</script>
