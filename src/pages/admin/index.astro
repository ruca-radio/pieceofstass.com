---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/admin-auth';
import { kpiSummary, getOrdersKVFromEnv, listOrders } from '../../lib/orders-server';

const env = await requireAdmin(Astro);
if (!env) return Astro.redirect('/admin/sign-in?error=session');

const runtimeEnv = ((Astro.locals as Record<string, unknown>)?.runtime as Record<string, unknown>)?.env as Record<string, unknown> | undefined;
const kv = getOrdersKVFromEnv(runtimeEnv);

const [kpis, { orders: recentOrders }] = await Promise.all([
  kpiSummary(kv),
  listOrders(kv, { limit: 8 }),
]);

function formatMoney(n: number) {
  return `$${n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
}

const statusBadgeClass: Record<string, string> = {
  pending: 'adm-badge-pending',
  payment_captured: 'adm-badge-captured',
  sent_to_supplier: 'adm-badge-supplier',
  shipped: 'adm-badge-shipped',
  delivered: 'adm-badge-delivered',
  refunded: 'adm-badge-refunded',
  cancelled: 'adm-badge-cancelled',
};

const statusLabel: Record<string, string> = {
  pending: 'Pending',
  payment_captured: 'Paid',
  sent_to_supplier: 'Sent',
  shipped: 'Shipped',
  delivered: 'Delivered',
  refunded: 'Refunded',
  cancelled: 'Cancelled',
};
---
<AdminLayout title="Dashboard" activeNav="dashboard">

  <!-- KPI strip -->
  <div class="adm-kpi-grid">
    <div class="adm-kpi">
      <div class="adm-kpi-label">Today Orders</div>
      <div class="adm-kpi-value">{kpis.today_count}</div>
      <div class="adm-kpi-sub">{formatMoney(kpis.today_revenue)} revenue</div>
    </div>
    <div class="adm-kpi">
      <div class="adm-kpi-label">7-Day Orders</div>
      <div class="adm-kpi-value">{kpis.week_count}</div>
      <div class="adm-kpi-sub">{formatMoney(kpis.week_revenue)} revenue</div>
    </div>
    <div class="adm-kpi">
      <div class="adm-kpi-label">30-Day Orders</div>
      <div class="adm-kpi-value">{kpis.month_count}</div>
      <div class="adm-kpi-sub">{formatMoney(kpis.month_revenue)} revenue</div>
    </div>
    <div class="adm-kpi">
      <div class="adm-kpi-label">Top Product (30d)</div>
      <div class="adm-kpi-value" style="font-size:16px;line-height:1.2;padding-top:2px;">
        {kpis.top_product_title ?? '—'}
      </div>
      <div class="adm-kpi-sub">{kpis.top_product_count} units sold</div>
    </div>
    <div class="adm-kpi">
      <div class="adm-kpi-label">Abandoned Carts</div>
      <div class="adm-kpi-value">{kpis.abandoned_carts_count}</div>
      <div class="adm-kpi-sub"><a href="/admin/abandoned-carts" style="color:var(--adm-violet);text-decoration:none;">View →</a></div>
    </div>
  </div>

  <!-- Quick links -->
  <div style="display:flex;gap:8px;margin-bottom:28px;flex-wrap:wrap;">
    <a href="/admin/orders" class="adm-btn adm-btn-secondary">All Orders</a>
    <a href="/admin/orders?status=payment_captured" class="adm-btn adm-btn-secondary">Needs Fulfillment</a>
    <a href="/admin/products" class="adm-btn adm-btn-secondary">Products</a>
    <a href="/admin/customers" class="adm-btn adm-btn-secondary">Customers</a>
  </div>

  <!-- Recent orders -->
  <div class="adm-section-title">Recent Orders</div>
  <div class="adm-card" style="padding:0;overflow:hidden;">
    {recentOrders.length === 0 ? (
      <div style="padding:24px;color:var(--adm-muted);text-align:center;">No orders yet.</div>
    ) : (
      <table class="adm-table">
        <thead>
          <tr>
            <th>Order ID</th>
            <th>Date</th>
            <th>Customer</th>
            <th>Items</th>
            <th>Total</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {recentOrders.map((o) => (
            <tr>
              <td>
                <a href={`/admin/orders/${o.id}`} class="adm-mono" style="font-size:12px;">{o.id}</a>
              </td>
              <td class="adm-mono" style="font-size:11px;color:var(--adm-muted);">{formatDate(o.created_at)}</td>
              <td>{o.customer_email}</td>
              <td style="color:var(--adm-muted);">{o.items.length} item{o.items.length !== 1 ? 's' : ''}</td>
              <td class="adm-mono">{formatMoney(o.total)}</td>
              <td>
                <span class={`adm-badge ${statusBadgeClass[o.status] ?? ''}`}>
                  {statusLabel[o.status] ?? o.status}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

</AdminLayout>
