---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/admin-auth';
import { kpiSummary, getOrdersKVFromEnv, listOrders } from '../../lib/orders-server';

const env = await requireAdmin(Astro);
if (!env) return Astro.redirect('/admin/sign-in?error=session');

const runtimeEnv = ((Astro.locals as Record<string, unknown>)?.runtime as Record<string, unknown>)?.env as Record<string, unknown> | undefined;
const kv = getOrdersKVFromEnv(runtimeEnv);

const [kpis, { orders: recentOrders }] = await Promise.all([
  kpiSummary(kv),
  listOrders(kv, { limit: 8 }),
]);

function formatMoney(n: number) {
  return `$${n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
}
function formatMoneyFull(n: number) {
  return `$${n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
}

function daysAgo(iso: string) {
  return Math.floor((Date.now() - new Date(iso).getTime()) / (24 * 60 * 60 * 1000));
}

const statusBadgeClass: Record<string, string> = {
  pending: 'adm-badge-pending',
  payment_captured: 'adm-badge-captured',
  sent_to_supplier: 'adm-badge-supplier',
  shipped: 'adm-badge-shipped',
  delivered: 'adm-badge-delivered',
  refunded: 'adm-badge-refunded',
  cancelled: 'adm-badge-cancelled',
};

const statusLabel: Record<string, string> = {
  pending: 'Pending',
  payment_captured: 'Paid',
  sent_to_supplier: 'Sent',
  shipped: 'Shipped',
  delivered: 'Delivered',
  refunded: 'Refunded',
  cancelled: 'Cancelled',
};

const attentionItems = [
  ...kpis.stuck_orders.map(o => ({
    type: 'stuck',
    label: `Order ${o.id} stuck in "Paid" for ${daysAgo(o.created_at)}d`,
    href: `/admin/orders/${o.id}`,
    severity: 'error',
  })),
  ...kpis.overdue_shipments.map(o => ({
    type: 'overdue',
    label: `Order ${o.id} shipped ${daysAgo(o.updated_at)}d ago — no delivery confirmation`,
    href: `/admin/orders/${o.id}`,
    severity: 'warning',
  })),
];

const hasAttention = attentionItems.length > 0;
---
<AdminLayout title="Dashboard" activeNav="dashboard">

  <!-- KPI grid — row 1 -->
  <div class="adm-kpi-grid">
    <div class="adm-kpi">
      <div class="adm-kpi-label">Today Revenue</div>
      <div class="adm-kpi-value">{formatMoney(kpis.today_revenue)}</div>
      <div class="adm-kpi-sub">{kpis.today_count} order{kpis.today_count !== 1 ? 's' : ''}</div>
    </div>
    <div class="adm-kpi">
      <div class="adm-kpi-label">7-Day Revenue</div>
      <div class="adm-kpi-value">{formatMoney(kpis.week_revenue)}</div>
      <div class="adm-kpi-sub">{kpis.week_count} orders</div>
    </div>
    <div class="adm-kpi">
      <div class="adm-kpi-label">30-Day Revenue</div>
      <div class="adm-kpi-value">{formatMoney(kpis.month_revenue)}</div>
      <div class="adm-kpi-sub">{kpis.month_count} orders</div>
    </div>
    <div class="adm-kpi">
      <div class="adm-kpi-label">AOV (30d)</div>
      <div class="adm-kpi-value">{formatMoney(kpis.aov_30d)}</div>
      <div class="adm-kpi-sub">avg order value</div>
    </div>
    <div class="adm-kpi">
      <div class="adm-kpi-label">Pending Fulfillment</div>
      <div class="adm-kpi-value" style={kpis.pending_fulfillment_count > 0 ? 'color:var(--adm-warning)' : ''}>
        {kpis.pending_fulfillment_count}
      </div>
      <div class="adm-kpi-sub"><a href="/admin/orders?status=payment_captured" style="color:var(--adm-violet);text-decoration:none;">View →</a></div>
    </div>
    <div class="adm-kpi">
      <div class="adm-kpi-label">Refund Rate (30d)</div>
      <div class="adm-kpi-value" style={kpis.refund_rate_30d > 0.05 ? 'color:var(--adm-error)' : ''}>
        {(kpis.refund_rate_30d * 100).toFixed(1)}%
      </div>
      <div class="adm-kpi-sub">of 30d orders</div>
    </div>
    <div class="adm-kpi">
      <div class="adm-kpi-label">Abandoned Carts</div>
      <div class="adm-kpi-value">{kpis.abandoned_carts_count}</div>
      <div class="adm-kpi-sub"><a href="/admin/abandoned-carts" style="color:var(--adm-violet);text-decoration:none;">View →</a></div>
    </div>
    <div class="adm-kpi">
      <div class="adm-kpi-label">Conv. Rate</div>
      <div class="adm-kpi-value" style="font-size:16px;color:var(--adm-muted);">—</div>
      <div class="adm-kpi-sub">connect GA4 to populate</div>
    </div>
  </div>

  <!-- Attention card -->
  {hasAttention && (
    <div class="adm-card" style="margin-bottom:20px;border-color:rgba(232,163,61,0.4);background:rgba(232,163,61,0.06);">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="font-size:16px;">⚠</span>
        <div style="font-weight:700;font-size:14px;color:var(--adm-warning);">Things that need attention</div>
      </div>
      <div style="display:flex;flex-direction:column;gap:8px;">
        {attentionItems.map((item) => (
          <div style={`display:flex;align-items:flex-start;gap:10px;padding:8px 10px;border-radius:6px;background:rgba(0,0,0,0.2);`}>
            <span style={`font-size:12px;font-weight:700;${item.severity === 'error' ? 'color:var(--adm-error)' : 'color:var(--adm-warning)'}`}>
              {item.type === 'stuck' ? '⏰' : '🚢'}
            </span>
            <div style="flex:1;font-size:13px;">
              {item.label}
              <a href={item.href} style="margin-left:8px;color:var(--adm-violet);text-decoration:none;font-size:11px;">View →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}
  {!hasAttention && (
    <div class="adm-card" style="margin-bottom:20px;border-color:rgba(47,168,102,0.3);background:rgba(47,168,102,0.05);">
      <div style="display:flex;align-items:center;gap:8px;">
        <span style="color:var(--adm-success);">✓</span>
        <div style="font-size:13px;color:var(--adm-success);font-weight:600;">All clear — no orders need immediate attention.</div>
      </div>
    </div>
  )}

  <div style="display:grid;grid-template-columns:1fr 280px;gap:20px;align-items:start;">

    <div>
      <!-- Top 5 products by revenue -->
      {kpis.top_products_30d.length > 0 && (
        <div class="adm-card" style="margin-bottom:20px;">
          <div style="font-weight:700;font-size:14px;margin-bottom:12px;">Top Products — Last 30 Days</div>
          <table class="adm-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Product</th>
                <th>Units</th>
                <th>Revenue</th>
              </tr>
            </thead>
            <tbody>
              {kpis.top_products_30d.map((p, i) => (
                <tr>
                  <td style="color:var(--adm-muted);font-size:12px;">{i + 1}</td>
                  <td style="font-size:12px;">{p.title}</td>
                  <td style="font-size:12px;color:var(--adm-muted);">{p.qty}</td>
                  <td class="adm-mono" style="font-size:12px;">{formatMoney(p.revenue)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      <!-- Recent orders -->
      <div class="adm-section-title">Recent Orders</div>
      <div class="adm-card" style="padding:0;overflow:hidden;">
        {recentOrders.length === 0 ? (
          <div style="padding:24px;color:var(--adm-muted);text-align:center;">No orders yet.</div>
        ) : (
          <table class="adm-table">
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Date</th>
                <th>Customer</th>
                <th>Total</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              {recentOrders.map((o) => (
                <tr>
                  <td>
                    <a href={`/admin/orders/${o.id}`} class="adm-mono" style="font-size:12px;">{o.id}</a>
                  </td>
                  <td class="adm-mono" style="font-size:11px;color:var(--adm-muted);">{formatDate(o.created_at)}</td>
                  <td style="font-size:12px;">
                    <div>{o.customer_name ?? '—'}</div>
                    <div style="color:var(--adm-muted);font-size:11px;">{o.customer_email}</div>
                  </td>
                  <td class="adm-mono" style="font-size:13px;">{formatMoney(o.total)}</td>
                  <td>
                    <span class={`adm-badge ${statusBadgeClass[o.status] ?? ''}`}>
                      {statusLabel[o.status] ?? o.status}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
      <div style="margin-top:8px;text-align:right;">
        <a href="/admin/orders" class="adm-btn adm-btn-secondary" style="font-size:12px;">All Orders →</a>
      </div>
    </div>

    <!-- Right sidebar -->
    <div style="display:flex;flex-direction:column;gap:12px;">

      <!-- Quick links -->
      <div class="adm-card">
        <div style="font-weight:700;font-size:13px;margin-bottom:10px;">Quick Actions</div>
        <div style="display:flex;flex-direction:column;gap:6px;">
          <a href="/admin/orders?status=payment_captured" class="adm-btn adm-btn-secondary" style="font-size:12px;">
            📦 Needs Fulfillment ({kpis.pending_fulfillment_count})
          </a>
          <a href="/admin/orders" class="adm-btn adm-btn-secondary" style="font-size:12px;">
            All Orders
          </a>
          <a href="/admin/products" class="adm-btn adm-btn-secondary" style="font-size:12px;">
            Products
          </a>
          <a href="/admin/customers" class="adm-btn adm-btn-secondary" style="font-size:12px;">
            Customers
          </a>
          <a href="/admin/analytics" class="adm-btn adm-btn-secondary" style="font-size:12px;">
            Analytics →
          </a>
        </div>
      </div>

      <!-- Stripe quick-link -->
      <div class="adm-card" style="border-color:rgba(99,91,255,0.3);">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
          <span style="font-size:18px;">💳</span>
          <div style="font-weight:700;font-size:13px;">Stripe</div>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px;">
          <a href="https://dashboard.stripe.com/payments" target="_blank" class="adm-btn adm-btn-secondary" style="font-size:12px;">
            Payments ↗
          </a>
          <a href="https://dashboard.stripe.com/radar" target="_blank" class="adm-btn adm-btn-secondary" style="font-size:12px;">
            Radar / Disputes ↗
          </a>
          <a href="https://dashboard.stripe.com/balance" target="_blank" class="adm-btn adm-btn-secondary" style="font-size:12px;">
            Balance ↗
          </a>
        </div>
      </div>

    </div>
  </div>

</AdminLayout>
