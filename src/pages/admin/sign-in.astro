---
export const prerender = false;

import { requireAdmin } from '../../lib/admin-auth';

// If already signed in, redirect to dashboard
const env = await requireAdmin(Astro);
if (env) return Astro.redirect('/admin');

const error = Astro.url.searchParams.get('error');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Admin Sign In — Piece of Stass</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0f0f10; --surface: #1c1c1f; --border: #2a2a2e;
      --text: #e8e8e3; --muted: #8a8a8e; --lime: #C6FF3A; --ink: #0A0A0B;
      --error: #E5484D; --violet: #7B5CFF;
      --font: Inter, system-ui, sans-serif;
      --display: "Space Grotesk", Inter, sans-serif;
    }
    html, body {
      height: 100%; background: var(--bg); color: var(--text);
      font-family: var(--font); font-size: 14px; line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }
    .wrapper {
      min-height: 100vh; display: flex; flex-direction: column;
      align-items: center; justify-content: center; padding: 24px;
    }
    .card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 12px; padding: 32px; width: 100%; max-width: 360px;
    }
    .brand {
      font-family: var(--display); font-weight: 700; font-size: 22px;
      color: var(--lime); letter-spacing: -0.02em; margin-bottom: 4px;
    }
    .sub {
      font-size: 12px; color: var(--muted); text-transform: uppercase;
      letter-spacing: 0.06em; margin-bottom: 28px;
    }
    label {
      display: block; font-size: 11px; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--muted); margin-bottom: 5px;
    }
    input[type="password"] {
      width: 100%; background: #242427; border: 1px solid var(--border);
      border-radius: 6px; color: var(--text); font-family: var(--font);
      font-size: 15px; padding: 10px 12px; outline: none;
      transition: border-color 0.1s; margin-bottom: 16px;
    }
    input[type="password"]:focus { border-color: var(--violet); }
    button[type="submit"] {
      width: 100%; background: var(--lime); color: var(--ink);
      border: none; border-radius: 6px; font-family: var(--display);
      font-weight: 700; font-size: 15px; padding: 11px;
      cursor: pointer; transition: opacity 0.1s;
    }
    button[type="submit"]:hover { opacity: 0.88; }
    .err {
      background: rgba(229,72,77,0.12); border: 1px solid rgba(229,72,77,0.3);
      color: var(--error); border-radius: 6px; padding: 10px 12px;
      font-size: 13px; margin-bottom: 16px;
    }
    .footer { margin-top: 20px; text-align: center; font-size: 11px; color: var(--muted); }
    .footer a { color: var(--muted); text-decoration: none; }
    .footer a:hover { color: var(--text); }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="card">
      <div class="brand">Piece of Stass</div>
      <div class="sub">Admin Access</div>

      {error && (
        <div class="err">
          {error === 'invalid' ? 'Incorrect password. Try again.' : 'Session expired. Please sign in again.'}
        </div>
      )}

      <form method="POST" action="/api/admin/sign-in">
        <label for="password">Admin Password</label>
        <input
          type="password"
          id="password"
          name="password"
          autocomplete="current-password"
          autofocus
          required
        />
        <button type="submit">Sign in</button>
      </form>

      <div class="footer">
        <a href="/">← Back to store</a>
      </div>
    </div>
  </div>
</body>
</html>
