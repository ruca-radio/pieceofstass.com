---
export const prerender = false;

import { requireAdmin } from '../../lib/admin-auth';

// If already signed in, redirect to dashboard
const env = await requireAdmin(Astro);
if (env) return Astro.redirect('/admin');

const error = Astro.url.searchParams.get('error');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#0b0d10" />
  <title>Sign in — Piece of Stass Admin</title>
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://rsms.me/" />
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:        #0b0d10;
      --surface:   #14181d;
      --elev:      #1a1f26;
      --line:      #232830;
      --line-soft: #1c2128;
      --text:      #e6e8eb;
      --heading:   #f5f6f8;
      --muted:     #8a92a0;
      --faint:     #5a626d;
      --accent:    #d97e7e;
      --accent-h:  #e89292;
      --accent-soft: rgba(217,126,126,0.14);
      --accent-bd:   rgba(217,126,126,0.32);
      --error:     #d85a5a;
      --error-soft: rgba(216,90,90,0.14);
      --font: 'Inter', system-ui, -apple-system, sans-serif;
    }
    @supports (font-variation-settings: normal) {
      :root { --font: 'Inter var', system-ui, sans-serif; }
    }

    html, body {
      height: 100%;
      background:
        radial-gradient(ellipse 800px 600px at 50% -10%, rgba(217,126,126,0.06), transparent 60%),
        var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-feature-settings: 'cv11', 'ss01';
      font-size: 14px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }

    .wrapper {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 32px 24px;
    }

    .brand-mark {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 28px;
    }
    .brand-mark img {
      width: 40px;
      height: 40px;
      border-radius: 8px;
    }
    .brand-mark-text {
      font-size: 16px;
      font-weight: 600;
      color: var(--heading);
      letter-spacing: -0.01em;
      line-height: 1.1;
    }
    .brand-mark-sub {
      font-size: 11px;
      color: var(--faint);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 600;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 32px;
      width: 100%;
      max-width: 380px;
      box-shadow: 0 24px 60px -20px rgba(0,0,0,0.5), 0 1px 0 rgba(255,255,255,0.02) inset;
    }

    h1 {
      font-size: 18px;
      font-weight: 600;
      color: var(--heading);
      letter-spacing: -0.01em;
      margin-bottom: 4px;
    }
    .lead {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 24px;
    }

    label {
      display: block;
      font-size: 11.5px;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    input[type="password"] {
      width: 100%;
      padding: 11px 14px;
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: 8px;
      color: var(--text);
      font: inherit;
      font-size: 14px;
      transition: border-color 120ms, background 120ms;
      margin-bottom: 16px;
    }
    input[type="password"]:focus {
      outline: none;
      border-color: var(--accent-bd);
      background: var(--elev);
      box-shadow: 0 0 0 3px var(--accent-soft);
    }

    button[type="submit"] {
      width: 100%;
      padding: 11px;
      background: var(--accent);
      border: 0;
      border-radius: 8px;
      color: #1a0f0f;
      font: inherit;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: background 120ms;
    }
    button[type="submit"]:hover { background: var(--accent-h); }

    .err {
      background: var(--error-soft);
      border: 1px solid rgba(216,90,90,0.32);
      color: #f0a0a0;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 13px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .err::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--error);
      flex-shrink: 0;
    }

    .footer {
      margin-top: 22px;
      text-align: center;
      font-size: 12px;
      color: var(--faint);
    }
    .footer a {
      color: var(--muted);
      text-decoration: none;
      transition: color 120ms;
    }
    .footer a:hover { color: var(--text); }
  </style>
</head>
<body>
  <div class="wrapper">
    <a href="/" class="brand-mark" aria-label="Back to store">
      <img src="/brand/icon-192.png" alt="" width="40" height="40" />
      <div>
        <div class="brand-mark-text">Piece of Stass</div>
        <div class="brand-mark-sub">Admin</div>
      </div>
    </a>

    <div class="card">
      <h1>Welcome back</h1>
      <p class="lead">Sign in to manage the storefront.</p>

      {error && (
        <div class="err" role="alert">
          {error === 'invalid' ? 'Incorrect password. Try again.' : 'Session expired. Please sign in again.'}
        </div>
      )}

      <form method="POST" action="/api/admin/sign-in">
        <label for="password">Admin password</label>
        <input
          type="password"
          id="password"
          name="password"
          autocomplete="current-password"
          autofocus
          required
        />
        <button type="submit">Sign in</button>
      </form>

      <div class="footer">
        <a href="/">← Back to store</a>
      </div>
    </div>
  </div>
</body>
</html>
