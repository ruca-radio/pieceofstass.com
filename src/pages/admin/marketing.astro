---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { requireAdmin } from '../../lib/admin-auth';
import { getOrdersKVFromEnv } from '../../lib/orders-server';

const env = await requireAdmin(Astro);
if (!env) return Astro.redirect('/admin/sign-in?error=session');

const runtimeEnv = ((Astro.locals as Record<string, unknown>)?.runtime as Record<string, unknown>)?.env as Record<string, unknown> | undefined;
const kv = getOrdersKVFromEnv(runtimeEnv);

// Load existing discounts
const idxRaw = await kv.get('discount_index');
const discountCodes: string[] = idxRaw ? JSON.parse(idxRaw) : [];
const discounts = (await Promise.all(discountCodes.map(async (c) => {
  const raw = await kv.get(`discount:${c}`);
  return raw ? JSON.parse(raw) : null;
}))).filter(Boolean);

function formatDate(iso: string | undefined) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---
<AdminLayout title="Marketing" activeNav="marketing">

  <!-- Integration status cards -->
  <div class="adm-section-title">Integrations</div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;margin-bottom:28px;">

    {['klaviyo', 'meta', 'tiktok'].map((provider) => (
      <div class="adm-card" id={`integration-${provider}`}>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
          <div style="font-weight:700;font-size:14px;text-transform:capitalize;">{provider === 'meta' ? 'Meta CAPI' : provider === 'tiktok' ? 'TikTok Events' : 'Klaviyo'}</div>
          <span class="adm-badge adm-badge-pending" id={`badge-${provider}`}>Checking…</span>
        </div>
        <div style="font-size:12px;color:var(--adm-muted);margin-bottom:12px;" id={`msg-${provider}`}>Pinging provider…</div>
        <div style="display:flex;gap:8px;">
          <button
            type="button"
            class="adm-btn adm-btn-secondary"
            style="font-size:12px;padding:5px 10px;"
            onclick={`checkIntegration('${provider}')`}
          >Refresh</button>
          <button
            type="button"
            class="adm-btn adm-btn-secondary"
            style="font-size:12px;padding:5px 10px;"
            onclick={`testEvent('${provider}')`}
          >Send Test Event</button>
        </div>
      </div>
    ))}
  </div>

  <!-- Discount codes CRUD -->
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
    <div class="adm-section-title" style="margin:0;">Discount Codes</div>
    <button type="button" class="adm-btn adm-btn-primary" style="font-size:12px;" onclick="openCreateDiscount()">
      + New Code
    </button>
  </div>

  <!-- Create form (hidden by default) -->
  <div id="create-discount-form" style="display:none;margin-bottom:16px;">
    <div class="adm-card">
      <div style="font-weight:700;font-size:13px;margin-bottom:14px;">Create Discount Code</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;">
        <div>
          <label class="adm-label">Code *</label>
          <input type="text" id="dc-code" class="adm-input" placeholder="SAVE20" style="font-size:13px;text-transform:uppercase;" />
        </div>
        <div>
          <label class="adm-label">Percent Off %</label>
          <input type="number" id="dc-percent" class="adm-input" placeholder="20" min="1" max="100" style="font-size:13px;" />
        </div>
        <div>
          <label class="adm-label">Fixed $ Off</label>
          <input type="number" id="dc-fixed" class="adm-input" placeholder="10.00" min="0.01" step="0.01" style="font-size:13px;" />
        </div>
        <div>
          <label class="adm-label">Valid From</label>
          <input type="date" id="dc-from" class="adm-input" style="font-size:13px;" />
        </div>
        <div>
          <label class="adm-label">Valid Until</label>
          <input type="date" id="dc-until" class="adm-input" style="font-size:13px;" />
        </div>
        <div>
          <label class="adm-label">Max Uses</label>
          <input type="number" id="dc-max-uses" class="adm-input" placeholder="∞" min="1" style="font-size:13px;" />
        </div>
        <div>
          <label class="adm-label">Applies To</label>
          <select id="dc-applies-to" class="adm-select" style="font-size:13px;">
            <option value="all">All products</option>
            <option value="footwear">Footwear</option>
            <option value="women">Women</option>
            <option value="men">Men</option>
            <option value="bags">Bags</option>
            <option value="watches">Watches</option>
            <option value="fragrance">Fragrance</option>
            <option value="tech">Tech</option>
            <option value="kids">Kids</option>
          </select>
        </div>
      </div>
      <div style="display:flex;gap:8px;margin-top:14px;">
        <button type="button" class="adm-btn adm-btn-primary" onclick="createDiscount()">Create Code</button>
        <button type="button" class="adm-btn adm-btn-secondary" onclick="document.getElementById('create-discount-form').style.display='none'">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Discounts table -->
  <div class="adm-card" style="padding:0;overflow:hidden;" id="discounts-card">
    {discounts.length === 0 ? (
      <div style="padding:32px;text-align:center;color:var(--adm-muted);">No discount codes yet. Create one above.</div>
    ) : (
      <table class="adm-table" id="discounts-table">
        <thead>
          <tr>
            <th>Code</th>
            <th>Discount</th>
            <th>Applies To</th>
            <th>Valid</th>
            <th>Used / Max</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="discounts-tbody">
          {discounts.map((d) => {
            const now = Date.now();
            const isExpired = d.valid_until && new Date(d.valid_until).getTime() < now;
            const isNotStarted = d.valid_from && new Date(d.valid_from).getTime() > now;
            const isMaxed = d.max_uses && d.used_count >= d.max_uses;
            const status = isExpired ? 'expired' : isNotStarted ? 'scheduled' : isMaxed ? 'maxed' : 'active';
            return (
              <tr data-code={d.code}>
                <td class="adm-mono" style="font-size:13px;font-weight:700;color:var(--adm-lime);">{d.code}</td>
                <td style="font-size:13px;">
                  {d.percent ? `${d.percent}% off` : d.fixed ? `$${d.fixed} off` : '—'}
                </td>
                <td style="font-size:12px;color:var(--adm-muted);">{d.applies_to ?? 'all'}</td>
                <td style="font-size:12px;color:var(--adm-muted);">
                  {formatDate(d.valid_from)} – {formatDate(d.valid_until)}
                </td>
                <td style="font-size:12px;">
                  {d.used_count} / {d.max_uses ?? '∞'}
                </td>
                <td>
                  <span class={`adm-badge ${status === 'active' ? 'adm-badge-active' : status === 'expired' || status === 'maxed' ? 'adm-badge-cancelled' : 'adm-badge-pending'}`}>
                    {status}
                  </span>
                </td>
                <td>
                  <button
                    type="button"
                    class="adm-btn adm-btn-danger"
                    style="padding:4px 10px;font-size:12px;"
                    onclick={`deleteDiscount('${d.code}', this)`}
                  >Delete</button>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </div>

</AdminLayout>

<script>
  // ── Integration checks ────────────────────────────────────────────────────
  async function checkIntegration(provider) {
    const badge = document.getElementById(`badge-${provider}`);
    const msg = document.getElementById(`msg-${provider}`);
    badge.className = 'adm-badge adm-badge-pending';
    badge.textContent = 'Checking…';
    msg.textContent = 'Pinging provider…';
    try {
      const r = await fetch(`/api/admin/integrations/${provider}/status`);
      const data = await r.json();
      if (data.ok) {
        badge.className = 'adm-badge adm-badge-active';
        badge.textContent = 'Connected';
        msg.textContent = `Status ${data.http_status ?? 'OK'}`;
      } else {
        badge.className = 'adm-badge adm-badge-refunded';
        badge.textContent = data.status === 'not_configured' ? 'Not Configured' : 'Error';
        msg.textContent = data.message ?? data.error ?? `HTTP ${data.http_status}`;
      }
    } catch(e) {
      badge.className = 'adm-badge adm-badge-refunded';
      badge.textContent = 'Error';
      msg.textContent = String(e);
    }
  }

  async function testEvent(provider) {
    window.adminToast(`Sending test event to ${provider}…`, 'info');
    try {
      const r = await fetch(`/api/admin/integrations/${provider}/test-event`, { method: 'POST' });
      const data = await r.json();
      if (data.ok) window.adminToast(`Test event sent to ${provider} ✓`, 'success');
      else window.adminToast(`Test event failed: ${data.error ?? 'unknown error'}`, 'error');
    } catch(e) {
      window.adminToast(`Network error: ${e}`, 'error');
    }
  }

  // Check all integrations on load
  document.addEventListener('DOMContentLoaded', () => {
    ['klaviyo', 'meta', 'tiktok'].forEach(checkIntegration);
  });

  // ── Discount CRUD ─────────────────────────────────────────────────────────
  function openCreateDiscount() {
    const form = document.getElementById('create-discount-form');
    form.style.display = form.style.display === 'none' ? 'block' : 'none';
  }

  async function createDiscount() {
    const code = document.getElementById('dc-code').value.trim().toUpperCase();
    const percent = parseFloat(document.getElementById('dc-percent').value) || undefined;
    const fixed = parseFloat(document.getElementById('dc-fixed').value) || undefined;
    const valid_from = document.getElementById('dc-from').value || undefined;
    const valid_until = document.getElementById('dc-until').value || undefined;
    const max_uses = parseInt(document.getElementById('dc-max-uses').value) || undefined;
    const applies_to = document.getElementById('dc-applies-to').value;

    if (!code) { window.adminToast('Code is required', 'warning'); return; }
    if (!percent && !fixed) { window.adminToast('Enter a percent or fixed discount', 'warning'); return; }
    if (percent && fixed) { window.adminToast('Choose either percent OR fixed, not both', 'warning'); return; }

    try {
      const r = await fetch('/api/admin/discounts', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ code, percent, fixed, valid_from, valid_until, max_uses, applies_to }),
      });
      const data = await r.json();
      if (data.ok) {
        window.adminToast(`Discount code ${code} created`, 'success');
        setTimeout(() => location.reload(), 800);
      } else {
        window.adminToast(data.error || 'Create failed', 'error');
      }
    } catch(e) { window.adminToast('Network error', 'error'); }
  }

  async function deleteDiscount(code, btn) {
    if (!confirm(`Delete discount code ${code}? This cannot be undone.`)) return;
    btn.disabled = true;
    try {
      const r = await fetch(`/api/admin/discounts/${code}`, { method: 'DELETE' });
      const data = await r.json();
      if (data.ok) {
        window.adminToast(`Deleted ${code}`, 'success');
        btn.closest('tr').remove();
      } else {
        window.adminToast(data.error || 'Delete failed', 'error');
        btn.disabled = false;
      }
    } catch(e) { window.adminToast('Network error', 'error'); btn.disabled = false; }
  }
</script>
