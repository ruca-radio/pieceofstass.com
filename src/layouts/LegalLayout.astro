---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  lastUpdated?: string;
}

const { title, description, lastUpdated } = Astro.props;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://pieceofstass.com' },
    { '@type': 'ListItem', position: 2, name: title, item: `https://pieceofstass.com${Astro.url.pathname}` },
  ],
};
---

<BaseLayout title={`${title} — Piece of Stass`} description={description} ogImage="/og-default.png" noindex={false} jsonLd={[breadcrumbJsonLd]}>
  <div style="max-width: 720px; margin: 0 auto; padding: 48px 16px 80px;">
    <nav aria-label="Breadcrumb" style="margin-bottom: 32px;">
      <ol style="list-style: none; padding: 0; margin: 0; display: flex; gap: 8px; font-size: 12px; color: var(--color-muted); font-family: var(--font-family-mono);">
        <li><a href="/" style="color: var(--color-muted); text-decoration: none;">Home</a></li>
        <li aria-hidden="true" style="color: var(--color-slate);">/</li>
        <li aria-current="page" style="color: var(--color-espresso);">{title}</li>
      </ol>
    </nav>

    <header style="margin-bottom: 40px; padding-bottom: 32px; border-bottom: 1px solid var(--color-slate);">
      <h1 style="font-family: var(--font-family-display); font-weight: 700; font-size: clamp(30px, 5vw, 48px); letter-spacing: -0.02em; margin: 0 0 12px; color: var(--color-espresso);">{title}</h1>
      {lastUpdated && (
        <p style="font-family: var(--font-family-mono); font-size: 12px; color: var(--color-muted); margin: 0;">
          Last updated: {lastUpdated}
        </p>
      )}
    </header>

    <div class="legal-body">
      <slot />
    </div>
  </div>
</BaseLayout>

<style>
  .legal-body {
    color: var(--color-muted);
    font-size: 15px;
    line-height: 1.8;
  }
  .legal-body h2 {
    font-family: var(--font-family-display);
    font-weight: 700;
    font-size: 22px;
    letter-spacing: -0.01em;
    color: var(--color-espresso);
    margin: 48px 0 16px;
    padding-top: 24px;
    border-top: 1px solid var(--color-slate);
  }
  .legal-body h3 {
    font-family: var(--font-family-display);
    font-weight: 600;
    font-size: 17px;
    color: var(--color-espresso);
    margin: 28px 0 10px;
  }
  .legal-body p {
    margin: 0 0 16px;
  }
  .legal-body ul, .legal-body ol {
    margin: 0 0 16px;
    padding-left: 24px;
  }
  .legal-body li {
    margin-bottom: 8px;
  }
  .legal-body a {
    color: var(--color-lime);
    text-decoration: none;
  }
  .legal-body a:hover {
    text-decoration: underline;
  }
  .legal-body strong {
    color: var(--color-espresso);
    font-weight: 600;
  }
  .legal-body code {
    font-family: var(--font-family-mono);
    font-size: 13px;
    background: var(--color-charcoal);
    padding: 2px 6px;
    border-radius: 4px;
  }
  .legal-body blockquote {
    border-left: 3px solid var(--color-lime);
    margin: 0 0 16px;
    padding: 12px 20px;
    background: rgba(178,94,107,0.04);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
  .legal-body hr {
    border: none;
    border-top: 1px solid var(--color-slate);
    margin: 32px 0;
  }
</style>
