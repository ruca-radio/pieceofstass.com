---
/**
 * AdminLayout.astro — shell for all /admin/* pages.
 * Left-rail nav with all sections, top bar with global search + profile dropdown.
 * Toast notification system (global, accessible via window.adminToast()).
 */
export interface Props {
  title: string;
  activeNav?: 'dashboard' | 'orders' | 'products' | 'customers' | 'carts' | 'inventory' | 'suppliers' | 'analytics' | 'marketing' | 'settings';
}

const { title, activeNav = 'dashboard' } = Astro.props;

const nav = [
  { key: 'dashboard',  label: 'Dashboard',        href: '/admin',                icon: '▦' },
  { key: 'orders',     label: 'Orders',            href: '/admin/orders',         icon: '📦' },
  { key: 'products',   label: 'Products',          href: '/admin/products',       icon: '🏷' },
  { key: 'customers',  label: 'Customers',         href: '/admin/customers',      icon: '👤' },
  { key: 'carts',      label: 'Abandoned Carts',   href: '/admin/abandoned-carts',icon: '🛒' },
  { key: 'inventory',  label: 'Inventory',         href: '/admin/inventory',      icon: '📋' },
  { key: 'suppliers',  label: 'Suppliers',         href: '/admin/suppliers',      icon: '🏭' },
  { key: 'analytics',  label: 'Analytics',         href: '/admin/analytics',      icon: '📈' },
  { key: 'marketing',  label: 'Marketing',         href: '/admin/marketing',      icon: '📣' },
  { key: 'settings',   label: 'Settings',          href: '/admin/settings',       icon: '⚙' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} — Piece of Stass Admin</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --adm-bg: #0f0f10;
      --adm-rail: #141416;
      --adm-surface: #1c1c1f;
      --adm-surface2: #242427;
      --adm-border: #2a2a2e;
      --adm-text: #e8e8e3;
      --adm-muted: #8a8a8e;
      --adm-lime: #C6FF3A;
      --adm-ink: #0A0A0B;
      --adm-violet: #7B5CFF;
      --adm-success: #2FA866;
      --adm-error: #E5484D;
      --adm-warning: #E8A33D;
      --adm-font: Inter, system-ui, -apple-system, sans-serif;
      --adm-mono: "Space Mono", ui-monospace, monospace;
      --adm-display: "Space Grotesk", Inter, sans-serif;
    }

    html, body {
      height: 100%;
      background: var(--adm-bg);
      color: var(--adm-text);
      font-family: var(--adm-font);
      font-size: 14px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }

    .adm-shell {
      display: flex;
      min-height: 100vh;
    }

    /* ── Left Rail ── */
    .adm-rail {
      width: 220px;
      flex-shrink: 0;
      background: var(--adm-rail);
      border-right: 1px solid var(--adm-border);
      display: flex;
      flex-direction: column;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }

    .adm-brand {
      padding: 20px 16px 16px;
      border-bottom: 1px solid var(--adm-border);
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .adm-brand-name {
      font-family: var(--adm-display);
      font-weight: 700;
      font-size: 15px;
      color: var(--adm-lime);
      letter-spacing: -0.01em;
    }
    .adm-brand-sub {
      font-size: 11px;
      color: var(--adm-muted);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .adm-nav {
      padding: 12px 8px;
      flex: 1;
    }
    .adm-nav-item {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 8px 10px;
      border-radius: 6px;
      text-decoration: none;
      color: var(--adm-muted);
      font-size: 13px;
      font-weight: 500;
      transition: background 0.1s, color 0.1s;
      margin-bottom: 2px;
    }
    .adm-nav-item:hover {
      background: var(--adm-surface);
      color: var(--adm-text);
    }
    .adm-nav-item.active {
      background: var(--adm-surface2);
      color: var(--adm-lime);
      font-weight: 600;
    }
    .adm-nav-icon {
      width: 18px;
      text-align: center;
      font-size: 14px;
      flex-shrink: 0;
    }
    .adm-nav-section {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--adm-muted);
      padding: 10px 10px 4px;
      opacity: 0.6;
    }

    .adm-rail-footer {
      padding: 12px 8px;
      border-top: 1px solid var(--adm-border);
    }
    .adm-signout {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 8px 10px;
      border-radius: 6px;
      color: var(--adm-muted);
      font-size: 13px;
      font-weight: 500;
      text-decoration: none;
      cursor: pointer;
      background: none;
      border: none;
      width: 100%;
      text-align: left;
      transition: background 0.1s, color 0.1s;
    }
    .adm-signout:hover {
      background: var(--adm-surface);
      color: var(--adm-error);
    }

    /* ── Main Area ── */
    .adm-main {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-width: 0;
      overflow-x: auto;
    }

    .adm-topbar {
      padding: 10px 24px;
      border-bottom: 1px solid var(--adm-border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: var(--adm-rail);
      position: sticky;
      top: 0;
      z-index: 10;
      gap: 16px;
    }
    .adm-page-title {
      font-family: var(--adm-display);
      font-weight: 700;
      font-size: 17px;
      letter-spacing: -0.01em;
      color: var(--adm-text);
      white-space: nowrap;
    }

    /* Global search */
    .adm-global-search {
      flex: 1;
      max-width: 400px;
      position: relative;
    }
    .adm-global-search input {
      width: 100%;
      background: var(--adm-surface2);
      border: 1px solid var(--adm-border);
      border-radius: 6px;
      color: var(--adm-text);
      font-family: var(--adm-font);
      font-size: 13px;
      padding: 6px 10px 6px 32px;
      outline: none;
      transition: border-color 0.15s;
    }
    .adm-global-search input:focus {
      border-color: var(--adm-violet);
    }
    .adm-global-search input::placeholder {
      color: var(--adm-muted);
    }
    .adm-search-icon {
      position: absolute;
      left: 10px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--adm-muted);
      font-size: 13px;
      pointer-events: none;
    }
    .adm-search-results {
      position: absolute;
      top: calc(100% + 4px);
      left: 0;
      right: 0;
      background: var(--adm-surface);
      border: 1px solid var(--adm-border);
      border-radius: 8px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      z-index: 100;
      display: none;
      max-height: 360px;
      overflow-y: auto;
    }
    .adm-search-results.open { display: block; }
    .adm-search-result-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      cursor: pointer;
      text-decoration: none;
      color: var(--adm-text);
      font-size: 13px;
      border-bottom: 1px solid var(--adm-border);
    }
    .adm-search-result-item:last-child { border-bottom: none; }
    .adm-search-result-item:hover { background: var(--adm-surface2); }
    .adm-search-result-label {
      font-size: 11px;
      color: var(--adm-muted);
      font-family: var(--adm-mono);
    }

    .adm-topbar-right {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }
    .adm-store-link {
      color: var(--adm-violet);
      text-decoration: none;
      font-family: var(--adm-font);
      font-size: 12px;
      padding: 4px 10px;
      border: 1px solid var(--adm-border);
      border-radius: 4px;
      transition: border-color 0.1s;
      white-space: nowrap;
    }
    .adm-store-link:hover { border-color: var(--adm-violet); }

    .adm-content {
      flex: 1;
      padding: 24px;
    }

    /* ── Utility classes for pages ── */
    .adm-card {
      background: var(--adm-surface);
      border: 1px solid var(--adm-border);
      border-radius: 8px;
      padding: 16px;
    }
    .adm-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    .adm-table th {
      text-align: left;
      padding: 8px 12px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--adm-muted);
      border-bottom: 1px solid var(--adm-border);
      white-space: nowrap;
      cursor: pointer;
      user-select: none;
    }
    .adm-table th:hover { color: var(--adm-text); }
    .adm-table td {
      padding: 10px 12px;
      border-bottom: 1px solid var(--adm-border);
      color: var(--adm-text);
      vertical-align: middle;
    }
    .adm-table tr:last-child td { border-bottom: none; }
    .adm-table tbody tr:hover td { background: var(--adm-surface2); }
    .adm-table a { color: var(--adm-lime); text-decoration: none; }
    .adm-table a:hover { text-decoration: underline; }

    .adm-checkbox {
      width: 15px;
      height: 15px;
      cursor: pointer;
      accent-color: var(--adm-lime);
    }

    .adm-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      white-space: nowrap;
    }
    .adm-badge-pending    { background: rgba(232,163,61,0.15); color: #E8A33D; }
    .adm-badge-captured   { background: rgba(111,123,95,0.15); color: #a388ff; }
    .adm-badge-supplier   { background: rgba(178,94,107,0.12); color: var(--adm-lime); }
    .adm-badge-shipped    { background: rgba(47,168,102,0.15); color: var(--adm-success); }
    .adm-badge-delivered  { background: rgba(47,168,102,0.2);  color: var(--adm-success); }
    .adm-badge-refunded   { background: rgba(229,72,77,0.12);  color: var(--adm-error); }
    .adm-badge-cancelled  { background: rgba(138,138,142,0.12); color: var(--adm-muted); }
    .adm-badge-active     { background: rgba(47,168,102,0.15); color: var(--adm-success); }
    .adm-badge-draft      { background: rgba(138,138,142,0.12); color: var(--adm-muted); }
    .adm-badge-warning    { background: rgba(232,163,61,0.15); color: var(--adm-warning); }

    .adm-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      border: 1px solid transparent;
      text-decoration: none;
      transition: opacity 0.1s, border-color 0.1s;
      white-space: nowrap;
      font-family: var(--adm-font);
    }
    .adm-btn-primary   { background: var(--adm-lime); color: var(--adm-ink); }
    .adm-btn-secondary { background: var(--adm-surface2); color: var(--adm-text); border-color: var(--adm-border); }
    .adm-btn-danger    { background: rgba(229,72,77,0.15); color: var(--adm-error); border-color: rgba(229,72,77,0.3); }
    .adm-btn-success   { background: rgba(47,168,102,0.15); color: var(--adm-success); border-color: rgba(47,168,102,0.3); }
    .adm-btn:hover     { opacity: 0.85; }
    .adm-btn:disabled  { opacity: 0.4; cursor: not-allowed; }

    .adm-input, .adm-select, .adm-textarea {
      background: var(--adm-surface2);
      border: 1px solid var(--adm-border);
      border-radius: 6px;
      color: var(--adm-text);
      font-family: var(--adm-font);
      font-size: 13px;
      padding: 7px 10px;
      outline: none;
      width: 100%;
      transition: border-color 0.1s;
    }
    .adm-input:focus, .adm-select:focus, .adm-textarea:focus {
      border-color: var(--adm-violet);
    }
    .adm-input::placeholder { color: var(--adm-muted); }
    .adm-textarea { resize: vertical; min-height: 80px; }

    .adm-label {
      display: block;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--adm-muted);
      margin-bottom: 5px;
    }

    .adm-kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
      gap: 12px;
      margin-bottom: 24px;
    }
    .adm-kpi {
      background: var(--adm-surface);
      border: 1px solid var(--adm-border);
      border-radius: 8px;
      padding: 14px 16px;
    }
    .adm-kpi-label {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--adm-muted);
      margin-bottom: 6px;
    }
    .adm-kpi-value {
      font-family: var(--adm-display);
      font-weight: 700;
      font-size: 24px;
      letter-spacing: -0.02em;
      color: var(--adm-text);
      line-height: 1;
    }
    .adm-kpi-sub {
      font-size: 12px;
      color: var(--adm-muted);
      margin-top: 4px;
      font-family: var(--adm-mono);
    }

    .adm-section-title {
      font-family: var(--adm-display);
      font-weight: 700;
      font-size: 16px;
      letter-spacing: -0.01em;
      margin-bottom: 12px;
      color: var(--adm-text);
    }

    .adm-filters {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 16px;
      align-items: flex-end;
    }

    .adm-mono { font-family: var(--adm-mono); }
    .adm-text-muted { color: var(--adm-muted); }
    .adm-text-lime  { color: var(--adm-lime); }
    .adm-text-error { color: var(--adm-error); }
    .adm-text-success { color: var(--adm-success); }

    /* ── Timeline ── */
    .adm-timeline {
      position: relative;
      padding-left: 20px;
    }
    .adm-timeline::before {
      content: '';
      position: absolute;
      left: 6px;
      top: 6px;
      bottom: 6px;
      width: 1px;
      background: var(--adm-border);
    }
    .adm-timeline-event {
      position: relative;
      margin-bottom: 16px;
    }
    .adm-timeline-event::before {
      content: '';
      position: absolute;
      left: -17px;
      top: 5px;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--adm-border);
    }
    .adm-timeline-event.type-status_change::before { background: var(--adm-violet); }
    .adm-timeline-event.type-email_sent::before    { background: var(--adm-success); }
    .adm-timeline-event.type-refund::before        { background: var(--adm-error); }
    .adm-timeline-event.type-note::before          { background: var(--adm-warning); }
    .adm-timeline-event.type-supplier::before      { background: var(--adm-lime); }
    .adm-timeline-msg { font-size: 13px; color: var(--adm-text); }
    .adm-timeline-meta { font-size: 11px; color: var(--adm-muted); font-family: var(--adm-mono); margin-top: 2px; }

    /* ── Toast system ── */
    #adm-toast-container {
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 8px;
      pointer-events: none;
    }
    .adm-toast {
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      box-shadow: 0 4px 16px rgba(0,0,0,0.4);
      pointer-events: all;
      display: flex;
      align-items: center;
      gap: 10px;
      animation: adm-toast-in 0.2s ease;
      max-width: 360px;
    }
    .adm-toast-success { background: #162d1e; color: var(--adm-success); border: 1px solid rgba(47,168,102,0.3); }
    .adm-toast-error   { background: #2d1516; color: var(--adm-error);   border: 1px solid rgba(229,72,77,0.3); }
    .adm-toast-info    { background: #1a1a2e; color: #a388ff;             border: 1px solid rgba(123,92,255,0.3); }
    .adm-toast-warning { background: #2a2010; color: var(--adm-warning);  border: 1px solid rgba(232,163,61,0.3); }
    @keyframes adm-toast-in {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Confirm dialog ── */
    .adm-confirm-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.6);
      z-index: 1000;
      display: flex; align-items: center; justify-content: center;
    }
    .adm-confirm-box {
      background: var(--adm-surface);
      border: 1px solid var(--adm-border);
      border-radius: 12px;
      padding: 24px;
      max-width: 400px;
      width: 90%;
    }
    .adm-confirm-title { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
    .adm-confirm-msg   { font-size: 13px; color: var(--adm-muted); margin-bottom: 20px; line-height: 1.5; }
    .adm-confirm-btns  { display: flex; gap: 8px; justify-content: flex-end; }

    @media (max-width: 768px) {
      .adm-rail { width: 56px; }
      .adm-nav-item span:not(.adm-nav-icon) { display: none; }
      .adm-brand-name, .adm-brand-sub, .adm-nav-section { display: none; }
      .adm-global-search { display: none; }
    }
  </style>
</head>
<body>
  <div class="adm-shell">
    <!-- Left Rail Navigation -->
    <nav class="adm-rail">
      <div class="adm-brand">
        <div class="adm-brand-name">Piece of Stass</div>
        <div class="adm-brand-sub">Admin</div>
      </div>
      <div class="adm-nav">
        <div class="adm-nav-section">Operations</div>
        {nav.slice(0, 5).map((item) => (
          <a
            href={item.href}
            class={`adm-nav-item${activeNav === item.key ? ' active' : ''}`}
          >
            <span class="adm-nav-icon">{item.icon}</span>
            <span>{item.label}</span>
          </a>
        ))}
        <div class="adm-nav-section" style="margin-top:8px;">Management</div>
        {nav.slice(5).map((item) => (
          <a
            href={item.href}
            class={`adm-nav-item${activeNav === item.key ? ' active' : ''}`}
          >
            <span class="adm-nav-icon">{item.icon}</span>
            <span>{item.label}</span>
          </a>
        ))}
      </div>
      <div class="adm-rail-footer">
        <form method="POST" action="/api/admin/sign-out" style="margin:0">
          <button type="submit" class="adm-signout">
            <span class="adm-nav-icon">↩</span>
            <span>Sign out</span>
          </button>
        </form>
      </div>
    </nav>

    <!-- Main content area -->
    <div class="adm-main">
      <div class="adm-topbar">
        <h1 class="adm-page-title">{title}</h1>

        <!-- Global search -->
        <div class="adm-global-search">
          <span class="adm-search-icon">⌕</span>
          <input
            type="text"
            id="adm-global-search-input"
            placeholder="Search orders, products, customers…"
            autocomplete="off"
          />
          <div class="adm-search-results" id="adm-search-results"></div>
        </div>

        <div class="adm-topbar-right">
          <a href="https://dashboard.stripe.com" target="_blank" class="adm-store-link" title="Stripe Dashboard">Stripe ↗</a>
          <a href="/" class="adm-store-link" target="_blank">Store ↗</a>
        </div>
      </div>
      <main class="adm-content">
        <slot />
      </main>
    </div>
  </div>

  <!-- Toast container -->
  <div id="adm-toast-container"></div>

  <script>
    // ── Toast system ──────────────────────────────────────────────────────────
    window.adminToast = function(message, type = 'info', duration = 3500) {
      const container = document.getElementById('adm-toast-container');
      if (!container) return;
      const toast = document.createElement('div');
      const icons = { success: '✓', error: '✗', info: 'ℹ', warning: '⚠' };
      toast.className = `adm-toast adm-toast-${type}`;
      toast.innerHTML = `<span>${icons[type] || 'ℹ'}</span><span>${message}</span>`;
      container.appendChild(toast);
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transition = 'opacity 0.2s';
        setTimeout(() => toast.remove(), 200);
      }, duration);
    };

    // ── Global search ─────────────────────────────────────────────────────────
    const searchInput = document.getElementById('adm-global-search-input');
    const searchResults = document.getElementById('adm-search-results');
    let searchTimeout = null;

    if (searchInput && searchResults) {
      searchInput.addEventListener('input', (e) => {
        clearTimeout(searchTimeout);
        const q = e.target.value.trim();
        if (q.length < 2) {
          searchResults.classList.remove('open');
          return;
        }
        searchTimeout = setTimeout(async () => {
          try {
            const [ordersRes, customersRes] = await Promise.all([
              fetch(`/api/admin/orders?q=${encodeURIComponent(q)}&limit=5`),
              fetch(`/api/admin/customers?q=${encodeURIComponent(q)}&limit=5`),
            ]);
            const ordersData = ordersRes.ok ? await ordersRes.json() : { orders: [] };
            const customersData = customersRes.ok ? await customersRes.json() : { customers: [] };

            let html = '';
            for (const o of (ordersData.orders || [])) {
              html += `<a href="/admin/orders/${o.id}" class="adm-search-result-item">
                <span>📦</span>
                <span>
                  <div>${o.id}</div>
                  <div class="adm-search-result-label">${o.customer_email} · $${o.total}</div>
                </span>
              </a>`;
            }
            for (const c of (customersData.customers || [])) {
              html += `<a href="/admin/customers/${encodeURIComponent(c.email)}" class="adm-search-result-item">
                <span>👤</span>
                <span>
                  <div>${c.name || c.email}</div>
                  <div class="adm-search-result-label">${c.email} · ${c.orderCount} orders</div>
                </span>
              </a>`;
            }
            if (!html) {
              html = '<div style="padding:12px;color:var(--adm-muted);font-size:13px;">No results found</div>';
            }
            searchResults.innerHTML = html;
            searchResults.classList.add('open');
          } catch {}
        }, 250);
      });

      document.addEventListener('click', (e) => {
        if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
          searchResults.classList.remove('open');
        }
      });

      searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') searchResults.classList.remove('open');
      });
    }
  </script>
</body>
</html>
